            <div class="field"><label>Instalaciones contra incendio (bocas)</label><input class="input" type="number" min="0" name="instalaciones_incendio" value={(edificacion as any)?.instalaciones_incendio ?? ''} /></div>
            <div class="field"><label>Cantidad de habitaciones</label><input class="input" type="number" min="0" name="cantidad_habitaciones" value={(edificacion as any)?.cantidad_habitaciones ?? ''} /></div>
