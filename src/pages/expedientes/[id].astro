---
import AppLayout from '../../layouts/AppLayout.astro'
import { supabase, getSupabase } from '../../lib/supabase'
import { calcularPoligonal, calcularSuperficie } from '../../lib/poligonal'
import { CATEGORIAS_E1, INCISOS_E1, DESTINOS_E1 } from '../../lib/edificacionE1'

const token = Astro.cookies.get('sb-access-token')?.value ?? ''
const { data: { user } } = await supabase.auth.getUser(token)
const uid = user?.id ?? ''
const db = getSupabase(token)
const { id } = Astro.params

// Cargar expediente
const { data: exp } = await db
  .from('expedientes')
  .select('*')
  .eq('id', id).eq('user_id', uid)
  .single()

if (!exp) return Astro.redirect('/expedientes')

const DOCS_POR_PAGINA = 10
const docPage = Math.max(1, parseInt(Astro.url.searchParams.get('docpag') ?? '1') || 1)
const docFrom = (docPage - 1) * DOCS_POR_PAGINA
const docTo = docFrom + DOCS_POR_PAGINA - 1

// Cargar datos relacionados en paralelo
const [
  { data: inmueble },
  { data: expComitentes },
  { data: expTestigos },
  { data: poligonosRaw },
  { data: linderos },
  { data: edificacion },
  { data: documentos, count: documentosCount },
  { data: comitentesAll },
  { data: testigosAll },
  { data: profile },
] = await Promise.all([
  db.from('inmuebles').select('*').eq('expediente_id', id).maybeSingle(),
  db.from('exp_comitentes').select('*, comitentes(*)').eq('expediente_id', id),
  db.from('exp_testigos').select('*, testigos(*)').eq('expediente_id', id),
  db.from('poligono').select('*, lados(*), angulos(*)').eq('expediente_id', id).order('parcela_desde', { ascending: true, nullsFirst: true }),
  db.from('linderos').select('*').eq('expediente_id', id).maybeSingle(),
  db.from('edificacion').select('*').eq('expediente_id', id).maybeSingle(),
  db.from('documentos_generados').select('*', { count: 'exact' }).eq('expediente_id', id).order('generado_at', { ascending: false }).range(docFrom, docTo),
  db.from('comitentes').select('id,nombre,apellido,dni').eq('user_id', uid).order('apellido'),
  db.from('testigos').select('id,nombre,apellido,dni').eq('user_id', uid).order('apellido'),
  db.from('profiles').select('*').eq('id', uid).maybeSingle(),
])

// Un expediente puede tener varios polígonos (división en parcelas); ordenados por parcela_desde.
// TODO (paso 3): la UI de Tab 3 hoy solo usa `poligono` (el primero) — falta la UI de cards para
// crear/editar los polígonos siguientes.
const poligonos = poligonosRaw ?? []
const poligono = poligonos[0] ?? null

const docTotalPages = Math.max(1, Math.ceil((documentosCount ?? 0) / DOCS_POR_PAGINA))

let successMsg = ''
let errorMsg = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('_action') as string

  if (action === 'guardar_inmueble') {
    const tipoInscripcion = (form.get('tipo_inscripcion_registro') as string) || 'matricula'
    const payload = {
      expediente_id: id,
      tipo_inmueble: form.get('tipo_inmueble'),
      departamento: form.get('departamento'),
      localidad: form.get('localidad'),
      seccion: form.get('seccion') || null,
      fraccion: form.get('fraccion') || null,
      manzana: form.get('manzana') || null,
      parcela: form.get('parcela') || null,
      matricula_catastral: form.get('matricula_catastral'),
      tipo_inscripcion_registro: tipoInscripcion,
      matricula_registro: tipoInscripcion === 'matricula' ? (form.get('matricula_registro') || null) : null,
      registro_tomo:  tipoInscripcion === 'tomo' ? (form.get('registro_tomo')  || null) : null,
      registro_folio: tipoInscripcion === 'tomo' ? (form.get('registro_folio') || null) : null,
      registro_finca: tipoInscripcion === 'tomo' ? (form.get('registro_finca') || null) : null,
      // A diferencia de tomo/folio/finca (exclusivos del modo "Tomo"), el Año se pide en los
      // dos modos — el input activo es el que llega en el form (el del otro modo está
      // disabled y no se envía), así que se guarda sin condicionar al tipo de inscripción.
      registro_anio: form.get('registro_anio') || null,
      inscripcion_mayor_extension: form.get('inscripcion_mayor_extension') === 'on',
      matricula_municipal: form.get('matricula_municipal') || null,
      antecedentes_tecnicos: form.get('antecedentes_tecnicos') || null,
      propietario_anterior: form.get('propietario_anterior') || null,
      calle_frente: form.get('calle_frente') || null,
      calle_entre1: form.get('calle_entre1') || null,
      calle_entre2: form.get('calle_entre2') || null,
    }
    const { error } = inmueble
      ? await db.from('inmuebles').update(payload).eq('expediente_id', id)
      : await db.from('inmuebles').insert(payload)

    // Linderos de citación: se cargan acá (etapa previa a la mensura), no en Tab Mensura.
    const citacionPayload = {
      expediente_id: id,
      norte_citacion: form.get('norte_citacion') || null,
      sur_citacion: form.get('sur_citacion') || null,
      este_citacion: form.get('este_citacion') || null,
      oeste_citacion: form.get('oeste_citacion') || null,
    }
    if (linderos) await db.from('linderos').update(citacionPayload).eq('expediente_id', id)
    else await db.from('linderos').insert(citacionPayload)

    if (error) errorMsg = error.message
    else successMsg = 'Inmueble guardado.'
  }

  const eliminarPolId    = (form.get('eliminar_pol_id') as string) || ''
  const agregarPoligono  = (form.get('_agregar_poligono') as string) || ''

  if (eliminarPolId) {
    // Borra un polígono puntual (lados/angulos se van en cascada por FK).
    await db.from('poligono').delete().eq('id', eliminarPolId)
    successMsg = 'Polígono eliminado.'
  }

  if ((action === 'guardar_mensura' || agregarPoligono) && !eliminarPolId) {
    const cantPoligonos = parseInt(form.get('cantidad_poligonos') as string) || 0

    // Validar sumatoria angular de cada polígono ANTES de guardar nada
    // (en un polígono cerrado, la cantidad de ángulos = cantidad de vértices = cantidad de lados)
    for (let p = 0; p < cantPoligonos && !errorMsg; p++) {
      const cantAngulos = parseInt(form.get(`pol_${p}_cantidad_angulos`) as string) || 0
      if (cantAngulos >= 3) {
        let sumSeg = 0
        for (let i = 1; i <= cantAngulos; i++) {
          const va = (form.get(`pol_${p}_angulo_${i}_valor`) as string) || ''
          if (va) {
            const [gp, dp = ''] = va.split('.')
            const dec = dp.padEnd(4, '0')
            sumSeg += (parseInt(gp)||0)*3600 + (parseInt(dec.substring(0,2))||0)*60 + (parseInt(dec.substring(2,4))||0)
          }
        }
        if (sumSeg > 0) {
          const expectedSeg = (cantAngulos - 2) * 180 * 3600
          if (sumSeg !== expectedSeg) {
            const fmt = (s: number) =>
              `${Math.floor(s/3600)}° ${String(Math.floor((s%3600)/60)).padStart(2,'0')}' ${String(s%60).padStart(2,'0')}"`
            const diff = sumSeg - expectedSeg
            const sign = diff > 0 ? '+' : '-'
            const numParcela = form.get(`pol_${p}_parcela_desde`) || (p + 1)
            errorMsg = `Sumatoria angular incorrecta en Parcela ${numParcela} — Actual: ${fmt(sumSeg)} · Esperado: ${fmt(expectedSeg)} (${cantAngulos} ángulos → ${(cantAngulos-2)*180}°) · Diferencia: ${sign}${fmt(Math.abs(diff))}`
          }
        }
      }
    }

    if (!errorMsg) {
      await db.from('expedientes').update({
        numero_expediente: form.get('numero_expediente') || null,
        fecha_inicio: form.get('fecha_mensura') || null,
        hora_mensura: form.get('hora_mensura') || null,
        area_catastro: form.get('area_catastro') || null,
      }).eq('id', id)

      let maxParcelaHasta = 0

      for (let p = 0; p < cantPoligonos; p++) {
        const existingId  = (form.get(`pol_${p}_id`) as string) || ''
        const cantLados    = parseInt(form.get(`pol_${p}_cantidad_lados`) as string) || 0
        const cantAngulos  = parseInt(form.get(`pol_${p}_cantidad_angulos`) as string) || 0
        const parcelaDesde = parseInt(form.get(`pol_${p}_parcela_desde`) as string) || (p + 1)
        const parcelaHasta = parseInt(form.get(`pol_${p}_parcela_hasta`) as string) || parcelaDesde
        maxParcelaHasta = Math.max(maxParcelaHasta, parcelaDesde, parcelaHasta)

        const superficieManual = form.get(`pol_${p}_superficie_manual`) === 'on'

        // Superficie: manual = lo tipeado por el agrimensor; automática (default) = recalculada
        // acá a partir de lados/ángulos con el mismo método que la Planilla de Cálculos (Gauss/
        // shoelace sobre coordenadas compensadas) — no se confía en los campos numéricos del
        // form, que llegan deshabilitados y no se envían cuando no está en modo manual.
        let superficieM2: number | null
        if (superficieManual) {
          superficieM2 = parseFloat(form.get(`pol_${p}_superficie_m2`) as string) || null
          if (inmueble?.tipo_inmueble === 'rural') {
            const ha = parseFloat(form.get(`pol_${p}_superficie_ha`) as string) || 0
            const a  = parseFloat(form.get(`pol_${p}_superficie_a`)  as string) || 0
            const ca = parseFloat(form.get(`pol_${p}_superficie_ca`) as string) || 0
            if (ha > 0 || a > 0 || ca > 0) superficieM2 = ha * 10000 + a * 100 + ca
          }
        } else {
          const ladosForm = []
          for (let i = 1; i <= cantLados; i++) {
            ladosForm.push({ valor_m: parseFloat(form.get(`pol_${p}_lado_${i}_valor_m`) as string) || 0 })
          }
          const angulosForm = []
          for (let i = 1; i <= cantAngulos; i++) {
            const va = (form.get(`pol_${p}_angulo_${i}_valor`) as string) || ''
            const [gradosPart, decimalPart = ''] = va.split('.')
            const decStr = decimalPart.padEnd(4, '0')
            angulosForm.push({
              grados: parseInt(gradosPart) || 0,
              minutos: parseInt(decStr.substring(0, 2)) || 0,
              segundos: parseInt(decStr.substring(2, 4)) || 0,
            })
          }
          const n = Math.max(ladosForm.length, angulosForm.length)
          const calc = n >= 3 ? calcularPoligonal(ladosForm, angulosForm) : null
          superficieM2 = calc ? calcularSuperficie(calc) : null
        }

        const polPayload = {
          expediente_id: id,
          parcela_desde: parcelaDesde,
          parcela_hasta: parcelaHasta,
          superficie_m2: superficieM2,
          superficie_letras: form.get(`pol_${p}_superficie_letras`) || null,
          superficie_manual: superficieManual,
          cantidad_lados: cantLados,
          cantidad_angulos: cantAngulos,
        }

        let polId: string | null = existingId || null
        if (existingId) {
          await db.from('poligono').update(polPayload).eq('id', existingId)
        } else {
          const { data: newPol } = await db.from('poligono').insert(polPayload).select('id').single()
          polId = newPol?.id ?? null
        }

        // Guardar lados si se enviaron
        if (polId && cantLados > 0) {
          await db.from('lados').delete().eq('poligono_id', polId)
          for (let i = 1; i <= cantLados; i++) {
            const vm = form.get(`pol_${p}_lado_${i}_valor_m`) as string
            const vl = form.get(`pol_${p}_lado_${i}_valor_letras`) as string
            if (vm || vl) {
              await db.from('lados').insert({
                poligono_id: polId,
                orden: i,
                valor_m:      parseFloat(vm) || null,
                valor_letras: vl || null,
              })
            }
          }
        }

        // Guardar ángulos si se enviaron
        if (polId && cantAngulos > 0) {
          await db.from('angulos').delete().eq('poligono_id', polId)
          for (let i = 1; i <= cantAngulos; i++) {
            const va = form.get(`pol_${p}_angulo_${i}_valor`) as string
            const vl = form.get(`pol_${p}_angulo_${i}_valor_letras`) as string
            if (va || vl) {
              const [gradosPart, decimalPart = ''] = (va || '').split('.')
              const decStr = decimalPart.padEnd(4, '0')
              await db.from('angulos').insert({
                poligono_id:  polId,
                orden:        i,
                grados:       parseInt(gradosPart) || null,
                minutos:      parseInt(decStr.substring(0, 2)) || null,
                segundos:     parseInt(decStr.substring(2, 4)) || null,
                valor_letras: vl || null,
              })
            }
          }
        }
      }

      if (agregarPoligono) {
        // Numeración consecutiva: el nuevo polígono arranca donde terminó el último.
        await db.from('poligono').insert({
          expediente_id: id,
          parcela_desde: maxParcelaHasta + 1,
          parcela_hasta: maxParcelaHasta + 1,
          cantidad_lados: 0,
          cantidad_angulos: 0,
        })
        successMsg = 'Polígono agregado.'
      } else {
        successMsg = 'Mensura guardada.'
      }
    }
  }

  if (action === 'guardar_linderos') {
    // Los linderos de citación se cargan en Tab Inmueble (action guardar_inmueble).
    // Acá solo se guardan los de mensura: si "iguales" está tildado, se fuerzan iguales
    // a los de citación ya guardados (no se confía en los inputs deshabilitados del form).
    const iguales = form.get('linderos_iguales') === 'on'
    const lPayload = {
      expediente_id: id,
      linderos_iguales: iguales,
      norte_mensura: iguales ? (linderos?.norte_citacion ?? null) : (form.get('norte_mensura') || null),
      sur_mensura:   iguales ? (linderos?.sur_citacion   ?? null) : (form.get('sur_mensura')   || null),
      este_mensura:  iguales ? (linderos?.este_citacion  ?? null) : (form.get('este_mensura')  || null),
      oeste_mensura: iguales ? (linderos?.oeste_citacion ?? null) : (form.get('oeste_mensura') || null),
    }
    if (linderos) await db.from('linderos').update(lPayload).eq('expediente_id', id)
    else await db.from('linderos').insert(lPayload)
    successMsg = 'Linderos guardados.'
  }

  if (action === 'guardar_ddjj') {
    if (inmueble) {
      await db.from('inmuebles').update({
        agua_corriente: form.get('agua_corriente') === 'on',
        cloacas: form.get('cloacas') === 'on',
        personas_habitan: parseInt(form.get('personas_habitan') as string) || null,
        ultimo_anio_pago_impuesto: form.get('ultimo_anio_pago_impuesto') || null,
        receptoria: form.get('receptoria') || null,
      }).eq('expediente_id', id)
    }

    for (const ec of (expComitentes ?? []) as any[]) {
      await db.from('comitentes').update({
        nacionalidad: form.get(`com_${ec.id}_nacionalidad`) || null,
        tipo_documento: form.get(`com_${ec.id}_tipo_documento`) || 'DNI',
        domicilio_calle: form.get(`com_${ec.id}_domicilio_calle`) || null,
        domicilio_numero: form.get(`com_${ec.id}_domicilio_numero`) || null,
        domicilio_localidad: form.get(`com_${ec.id}_domicilio_localidad`) || null,
        domicilio_provincia: form.get(`com_${ec.id}_domicilio_provincia`) || null,
      }).eq('id', ec.comitente_id)

      await db.from('exp_comitentes').update({
        porcentaje_condominio: parseFloat(form.get(`com_${ec.id}_porcentaje`) as string) || 100,
        ausente_pais: form.get(`com_${ec.id}_ausente`) === 'on',
      }).eq('id', ec.id)
    }
    successMsg = 'Declaración Jurada guardada.'
  }

  if (action === 'guardar_ddjj_e1') {
    const caracteristicas: Record<string, string> = {}
    for (const cat of CATEGORIAS_E1) {
      const valor = form.get(`car_${cat.key}`) as string
      if (valor && INCISOS_E1.includes(valor)) caracteristicas[cat.key] = valor
    }
    // form.get(...) || null convertía un 0 real (pileta de natación vacía, superficie de
    // negocios en 0, etc.) en null, porque 0 es falsy en JS — se perdía el dato cargado.
    const numE1 = (name: string, entero: boolean) => {
      const raw = form.get(name) as string
      if (raw == null || raw === '') return null
      const n = entero ? parseInt(raw) : parseFloat(raw)
      return Number.isNaN(n) ? null : n
    }
    const payload = {
      expediente_id: id,
      destino_edificio: form.get('destino_edificio') || null,
      destino_otros_detalle: form.get('destino_otros_detalle') || null,
      estado_conservacion: form.get('estado_conservacion') || null,
      edad_edificio: numE1('edad_edificio', true),
      superficie_cubierta: numE1('superficie_cubierta', false),
      superficie_semicubierta: numE1('superficie_semicubierta', false),
      superficie_negocios: numE1('superficie_negocios', false),
      banos_principales: numE1('banos_principales', true),
      toilettes: numE1('toilettes', true),
      pileta_natacion: numE1('pileta_natacion', false),
      agua_caliente_central: numE1('agua_caliente_central', true),
      ascensores: numE1('ascensores', true),
      instalaciones_incendio: numE1('instalaciones_incendio', true),
      cantidad_habitaciones: numE1('cantidad_habitaciones', true),
      caracteristicas,
    }
    const { error: errorE1 } = edificacion
      ? await db.from('edificacion').update(payload).eq('expediente_id', id)
      : await db.from('edificacion').insert(payload)
    // Antes esto no chequeaba el resultado: si el insert/update fallaba (RLS, tipo de dato,
    // lo que sea), la página igual mostraba "Guardado correctamente" más abajo (ese mensaje
    // depende del redirect final de la línea ~440, no de si esto realmente escribió algo en
    // la base) y al volver a la Tab DDJJ aparecía todo en blanco, como si el botón no hiciera
    // nada. Ahora, si falla, se corta acá con un redirect propio que muestra el error real.
    if (errorE1) {
      console.error('guardar_ddjj_e1:', errorE1.message)
      return Astro.redirect(`/expedientes/${id}?tab=ddjj&warn=ddjj_e1_error&detalle=${encodeURIComponent(errorE1.message)}`)
    }
    successMsg = 'Características del edificio guardadas.'
  }

  if (action === 'agregar_comitente') {
    const comitenteId = form.get('comitente_id') as string
    const rol = form.get('rol') as string
    if (comitenteId) {
      await db.from('exp_comitentes').insert({
        expediente_id: id, comitente_id: comitenteId, rol, orden: (expComitentes?.length ?? 0) + 1
      })
      successMsg = 'Comitente agregado.'
    }
  }

  if (action === 'crear_comitente') {
    const { data: newC } = await db.from('comitentes').insert({
      user_id: uid,
      nombre: form.get('c_nombre'),
      apellido: form.get('c_apellido'),
      dni: form.get('c_dni'),
      domicilio: form.get('c_domicilio'),
      telefono: form.get('c_telefono'),
      email: form.get('c_email'),
    }).select('id').single()
    if (newC) {
      await db.from('exp_comitentes').insert({
        expediente_id: id, comitente_id: newC.id, rol: form.get('c_rol'), orden: (expComitentes?.length ?? 0) + 1
      })
      successMsg = 'Comitente creado y agregado.'
    }
  }

  if (action === 'quitar_comitente') {
    await db.from('exp_comitentes').delete().eq('id', form.get('exp_comitente_id'))
    successMsg = 'Comitente quitado.'
  }

  if (action === 'agregar_testigo') {
    const testigoId = form.get('testigo_id') as string
    if (testigoId) {
      await db.from('exp_testigos').insert({ expediente_id: id, testigo_id: testigoId })
      successMsg = 'Testigo agregado.'
    }
  }

  if (action === 'crear_testigo') {
    const { data: newT } = await db.from('testigos').insert({
      user_id: uid,
      nombre: form.get('t_nombre'),
      apellido: form.get('t_apellido'),
      dni: form.get('t_dni'),
      domicilio: form.get('t_domicilio'),
    }).select('id').single()
    if (newT) {
      await db.from('exp_testigos').insert({ expediente_id: id, testigo_id: newT.id })
      successMsg = 'Testigo creado y agregado.'
    }
  }

  if (action === 'editar_testigo') {
    await db.from('testigos').update({
      nombre: form.get('t_nombre'),
      apellido: form.get('t_apellido'),
      dni: form.get('t_dni'),
      domicilio: form.get('t_domicilio'),
    }).eq('id', form.get('testigo_id'))
    successMsg = 'Testigo actualizado.'
  }

  if (action === 'quitar_testigo') {
    await db.from('exp_testigos').delete().eq('id', form.get('exp_testigo_id'))
    successMsg = 'Testigo quitado.'
  }

  if (action === 'cambiar_estado') {
    const nuevoEstado = form.get('nuevo_estado') as string
    await db.from('expedientes').update({ estado: nuevoEstado }).eq('id', id)
    successMsg = 'Estado actualizado.'
  }

  return Astro.redirect(`/expedientes/${id}?tab=${form.get('_tab') ?? 'comitente'}&ok=1`)
}

const activeTab  = Astro.url.searchParams.get('tab') ?? 'comitente'
const ok         = Astro.url.searchParams.get('ok')
const warn       = Astro.url.searchParams.get('warn')
const detalle    = Astro.url.searchParams.get('detalle')

const DEPARTAMENTOS = [
  'Capital','Bella Vista','Berón de Astrada','Concepción','Curuzú Cuatiá',
  'Empedrado','Esquina','General Alvear','General Paz','Goya','Itatí',
  'Ituzaingó','Lavalle','Mburucuyá','Mercedes','Monte Caseros','Paso de los Libres',
  'Saladas','San Cosme','San Luis del Palmar','San Martín','San Miguel',
  'San Roque','Santo Tomé','Sauce'
]

// Identificador: número oficial si existe, sino nombre del primer comitente
const primerComitente = (expComitentes ?? [])[0]?.comitentes as any
const identificador = exp.numero_expediente
  ?? (primerComitente ? `${primerComitente.apellido}, ${primerComitente.nombre}` : null)
  ?? 'Nuevo expediente'
const tienNumero = !!exp.numero_expediente

// Datos para validar qué falta antes de habilitar la generación de cada documento
const datosValidacion = {
  tieneComitente: !!primerComitente,
  comitenteDni: !!primerComitente?.dni,
  inmuebleDepartamento: !!inmueble?.departamento,
  inmuebleLocalidad: !!inmueble?.localidad,
  inmueblePartida: !!inmueble?.matricula_catastral,
  profileNombre: !!(profile?.nombre && profile?.apellido),
  profileDni: !!(profile as any)?.dni,
  profileMatricula: !!profile?.matricula,
  profileMatriculaCatastro: !!(profile as any)?.matricula_catastro,
  fechaMensura: !!exp.fecha_inicio,
  horaMensura: !!(exp as any).hora_mensura,
  superficie: !!poligono?.superficie_m2,
  superficieLetras: !!poligono?.superficie_letras,
  linderosCompletos: !!(linderos?.norte_mensura && linderos?.sur_mensura && linderos?.este_mensura && linderos?.oeste_mensura),
  cantLados: (poligono as any)?.lados?.length ?? 0,
  cantAngulos: (poligono as any)?.angulos?.length ?? 0,
  inmuebleEsUrbano: (inmueble as any)?.tipo_inmueble === 'urbano',
  inmuebleEsRural: (inmueble as any)?.tipo_inmueble === 'rural',
  comitenteNacionalidad: !!(primerComitente as any)?.nacionalidad,
  comitenteDomicilio: !!((primerComitente as any)?.domicilio_calle && (primerComitente as any)?.domicilio_localidad),
  edificacionCargada: !!edificacion,
  edificacionCaracteristicas: Object.keys((edificacion as any)?.caracteristicas ?? {}).length > 0,
}

// Tab 3 Mensura: un expediente puede tener varios polígonos (división en parcelas).
// Si todavía no hay ninguno cargado, se muestra igual una card vacía (idx 0) para no
// cambiar la experiencia del caso simple de un solo polígono.
const poligonosParaUI = poligonos.length > 0 ? poligonos : [null as any]
const poligonosVarsForScript = poligonosParaUI.map((pol: any) => ({
  lados: pol?.lados ?? [],
  cantLados: pol?.cantidad_lados ?? 0,
  angulos: pol?.angulos ?? [],
  cantAngulos: pol?.cantidad_angulos ?? 0,
}))
---
<AppLayout title={identificador}>
  <div class="page-header">
    <div>
      <a href="/expedientes" class="back-link">← Expedientes</a>
      <h2>
        {tienNumero ? `Expediente ${exp.numero_expediente}` : identificador}
        {!tienNumero && <span style="font-size:0.75rem;color:var(--color-muted);font-weight:400;margin-left:0.5rem">(sin nº asignado)</span>}
        <span class={`badge badge-${exp.estado}`} style="margin-left:0.5rem">{exp.estado}</span>
      </h2>
    </div>
    <form method="POST">
      <input type="hidden" name="_action" value="cambiar_estado" />
      <input type="hidden" name="_tab" value={activeTab} />
      <select name="nuevo_estado" class="input" style="max-width:160px;display:inline-block">
        {['borrador','en_proceso','finalizado'].map(e => (
          <option value={e} selected={exp.estado === e}>{e.replace('_',' ')}</option>
        ))}
      </select>
      <button type="submit" class="btn btn-secondary btn-sm">Cambiar estado</button>
    </form>
  </div>

  {ok      && <div class="alert alert-success" style="margin-bottom:1rem">Guardado correctamente.</div>}
  {warn === 'sin_seleccion' && <div class="alert alert-error" style="margin-bottom:1rem">Seleccioná al menos un documento para generar.</div>}
  {warn === 'ddjj_no_implementada' && <div class="alert alert-error" style="margin-bottom:1rem">Ese formulario de Declaración Jurada todavía no está implementado.</div>}
  {warn === 'ddjj_falta_inmueble' && <div class="alert alert-error" style="margin-bottom:1rem">Completá primero la Tab 2 Inmueble antes de generar la Declaración Jurada.</div>}
  {warn === 'ddjj_tipo_incorrecto' && <div class="alert alert-error" style="margin-bottom:1rem">El Formulario U es solo para inmuebles urbanos y el SOR solo para rurales — revisá el tipo de inmueble cargado en la Tab 2.</div>}
  {warn === 'ddjj_e1_error' && <div class="alert alert-error" style="margin-bottom:1rem">No se pudieron guardar las características del edificio.{detalle ? ` Detalle: ${detalle}` : ''}</div>}
  {errorMsg && <div class="alert alert-error" style="margin-bottom:1rem">{errorMsg}</div>}

  <div class="card">
    <div class="tabs-nav">
      {[
        { key: 'comitente', label: '1. Comitente' },
        { key: 'inmueble',  label: '2. Inmueble' },
        { key: 'mensura',   label: '3. Mensura' },
        { key: 'testigos',  label: '4. Testigos' },
        { key: 'ddjj',      label: '5. DDJJ' },
        { key: 'documentos',label: '6. Documentos' },
      ].map(t => (
        <a href={`/expedientes/${id}?tab=${t.key}`} class={`tab-btn ${activeTab === t.key ? 'active' : ''}`}>
          {t.label}
        </a>
      ))}
    </div>

    <!-- TAB 1: COMITENTE -->
    {activeTab === 'comitente' && (
      <div>
        <h3 style="margin-bottom:1rem">Comitentes del expediente</h3>
        {warn === 'archivo_requerido' && <div class="alert alert-error" style="margin-bottom:1rem">Seleccioná un archivo para subir.</div>}
        {warn === 'formato_invalido'  && <div class="alert alert-error" style="margin-bottom:1rem">Formato no válido. Usá JPG, PNG o PDF.</div>}

        {(expComitentes ?? []).length > 0 && (
          <div style="margin-bottom:1.5rem">
            <table>
              <thead><tr><th>Nombre</th><th>DNI</th><th>Rol</th><th></th></tr></thead>
              <tbody>
                {expComitentes!.map((ec: any) => (
                  <>
                    <tr>
                      <td>{ec.comitentes?.apellido}, {ec.comitentes?.nombre}</td>
                      <td>{ec.comitentes?.dni ?? '—'}</td>
                      <td>{ec.rol}</td>
                      <td>
                        <form method="POST" style="display:inline">
                          <input type="hidden" name="_action" value="quitar_comitente" />
                          <input type="hidden" name="_tab" value="comitente" />
                          <input type="hidden" name="exp_comitente_id" value={ec.id} />
                          <button type="submit" class="btn btn-danger btn-sm">Quitar</button>
                        </form>
                      </td>
                    </tr>
                    <tr>
                      <td colspan="4" style="background:var(--color-bg);padding:0.875rem 1rem">
                        <div style="display:flex;gap:2rem;flex-wrap:wrap">
                          {(['frente','dorso'] as const).map(lado => {
                            const path = lado === 'frente' ? ec.comitentes?.dni_scan_path : ec.comitentes?.dni_scan_path_dorso
                            const esImagen = path && /\.(jpg|jpeg|png)$/i.test(path)
                            return (
                              <div style="display:flex;flex-direction:column;gap:0.5rem">
                                <span style="font-size:0.75rem;font-weight:700;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.04em">
                                  DNI {lado === 'frente' ? 'Frente' : 'Dorso'}
                                </span>
                                <div class="dni-preview-wrap" data-comitente-id={ec.comitentes?.id} data-lado={lado}>
                                  {path ? (
                                    <div class="dni-preview-inner" style="position:relative;width:140px;height:92px;border-radius:8px;overflow:hidden;border:1px solid var(--color-border);background:var(--color-surface)">
                                      {esImagen ? (
                                        <a href={`/api/documentos/descargar?path=${path}`} target="_blank" style="display:block;width:100%;height:100%">
                                          <img src={`/api/documentos/descargar?path=${path}`} alt={`DNI ${lado}`} class="dni-img"
                                            style="width:100%;height:100%;object-fit:cover;display:block" />
                                        </a>
                                      ) : (
                                        <a href={`/api/documentos/descargar?path=${path}`} class="badge badge-finalizado" style="text-decoration:none">Ver PDF</a>
                                      )}
                                      <button type="button" class="dni-remove-btn" data-comitente-id={ec.comitentes?.id} data-lado={lado} title="Quitar imagen">✕</button>
                                    </div>
                                  ) : (
                                    <div class="dni-preview-inner" style="width:140px;height:92px;border-radius:8px;overflow:hidden;border:1px dashed var(--color-border);background:var(--color-bg)">
                                      <div class="dni-placeholder" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:0.72rem;color:var(--color-text-secondary)">Sin cargar</div>
                                    </div>
                                  )}
                                </div>
                                <form method="POST" action="/api/comitentes/upload-dni" enctype="multipart/form-data" class="dni-upload-form" style="display:flex;flex-direction:column;gap:0.4rem">
                                  <input type="hidden" name="comitente_id" value={ec.comitentes?.id} />
                                  <input type="hidden" name="expediente_id" value={id} />
                                  <input type="hidden" name="lado" value={lado} />
                                  <label class="file-btn">
                                    Seleccionar imagen
                                    <input type="file" name="archivo" accept=".jpg,.jpeg,.png,.pdf" class="dni-file-input" hidden required />
                                  </label>
                                  <span class="file-name">Sin archivo seleccionado</span>
                                  <button type="submit" class="btn btn-primary btn-sm dni-submit-btn">Subir</button>
                                </form>
                              </div>
                            )
                          })}
                        </div>
                      </td>
                    </tr>
                  </>
                ))}
              </tbody>
            </table>
          </div>
        )}

        <details class="form-section">
          <summary>Buscar comitente existente</summary>
          <form method="POST" style="margin-top:1rem">
            <input type="hidden" name="_action" value="agregar_comitente" />
            <input type="hidden" name="_tab" value="comitente" />
            <div class="form-grid form-grid-2">
              <div class="field">
                <label>Comitente</label>
                <select class="input" name="comitente_id">
                  <option value="">Seleccionar...</option>
                  {(comitentesAll ?? []).map((c: any) => (
                    <option value={c.id}>{c.apellido}, {c.nombre} — DNI {c.dni}</option>
                  ))}
                </select>
              </div>
              <div class="field">
                <label>Rol</label>
                <select class="input" name="rol">
                  <option value="titular">Titular</option>
                  <option value="apoderado">Apoderado</option>
                  <option value="heredero">Heredero</option>
                  <option value="poseedor">Poseedor</option>
                </select>
              </div>
            </div>
            <button type="submit" class="btn btn-primary" style="margin-top:0.75rem">Agregar comitente</button>
          </form>
        </details>

        <details class="form-section" style="margin-top:1rem">
          <summary>Crear nuevo comitente</summary>
          <form method="POST" style="margin-top:1rem">
            <input type="hidden" name="_action" value="crear_comitente" />
            <input type="hidden" name="_tab" value="comitente" />
            <div class="form-grid form-grid-2">
              <div class="field"><label>Nombre</label><input class="input" name="c_nombre" required /></div>
              <div class="field"><label>Apellido</label><input class="input" name="c_apellido" required /></div>
              <div class="field"><label>DNI</label><input class="input" name="c_dni" /></div>
              <div class="field"><label>Teléfono</label><input class="input" name="c_telefono" /></div>
              <div class="field"><label>Email</label><input class="input" name="c_email" type="email" /></div>
              <div class="field">
                <label>Rol</label>
                <select class="input" name="c_rol">
                  <option value="titular">Titular</option>
                  <option value="apoderado">Apoderado</option>
                  <option value="heredero">Heredero</option>
                  <option value="poseedor">Poseedor</option>
                </select>
              </div>
            </div>
            <div class="field" style="margin-top:0.75rem"><label>Domicilio</label><input class="input" name="c_domicilio" /></div>
            <button type="submit" class="btn btn-primary" style="margin-top:0.75rem">Crear y agregar</button>
          </form>
        </details>
      </div>
    )}

    <!-- TAB 2: INMUEBLE -->
    {activeTab === 'inmueble' && (
      <form method="POST">
        <input type="hidden" name="_action" value="guardar_inmueble" />
        <input type="hidden" name="_tab" value="inmueble" />

        <!-- Tipo de inmueble (solo informativo, se define al crear) -->
        <input type="hidden" name="tipo_inmueble" value={inmueble?.tipo_inmueble ?? 'urbano'} />
        <div class="section-label">Tipo de inmueble</div>
        <div style="margin-bottom:1.5rem;margin-top:0.25rem">
          <span style="display:inline-block;padding:3px 12px;border-radius:99px;font-size:0.82rem;font-weight:600;background:var(--color-primary);color:#fff">
            {inmueble?.tipo_inmueble === 'rural' ? 'Rural' : 'Urbano'}
          </span>
          <span style="font-size:0.78rem;color:var(--color-text-secondary);margin-left:0.5rem">Se define al crear el expediente</span>
        </div>

        <!-- Identificación Catastral -->
        <div class="section-label">Identificación Catastral</div>
        <div class="form-grid form-grid-2" style="margin-bottom:1rem">
          <div class="field">
            <label>Departamento</label>
            <select class="input" name="departamento">
              <option value="">Seleccionar...</option>
              {DEPARTAMENTOS.map(d => (
                <option value={d} selected={inmueble?.departamento === d}>{d}</option>
              ))}
            </select>
          </div>
          <div class="field">
            <label>Localidad</label>
            <input class="input" name="localidad" value={inmueble?.localidad ?? ''} />
          </div>

          <!-- Solo URBANO: Manzana -->
          <div class="field campo-urbano" id="grupo_manzana" style={inmueble?.tipo_inmueble === 'rural' ? 'display:none' : ''}>
            <label>Manzana</label>
            <input class="input" name="manzana" id="input_manzana" value={inmueble?.manzana ?? ''}
              disabled={inmueble?.tipo_inmueble === 'rural'} />
          </div>

          <!-- Solo URBANO: Parcela -->
          <div class="field campo-urbano" id="grupo_parcela" style={inmueble?.tipo_inmueble === 'rural' ? 'display:none' : ''}>
            <label>Parcela</label>
            <input class="input" name="parcela" id="input_parcela" value={inmueble?.parcela ?? ''}
              disabled={inmueble?.tipo_inmueble === 'rural'} />
          </div>

          <!-- Solo RURAL: Sección Rural -->
          <div class="field campo-rural" id="grupo_seccion" style={inmueble?.tipo_inmueble !== 'rural' ? 'display:none' : ''}>
            <label id="lbl_seccion">Sección Rural</label>
            <input class="input" name="seccion" id="input_seccion" value={inmueble?.seccion ?? ''}
              disabled={inmueble?.tipo_inmueble !== 'rural'} />
          </div>

          <!-- Partida inmobiliaria (siempre) -->
          <div class="field">
            <label>Partida Inmobiliaria</label>
            <input class="input" name="matricula_catastral" value={inmueble?.matricula_catastral ?? ''}
              style="text-transform:uppercase" oninput="this.value = this.value.toUpperCase()" />
          </div>

          <!-- Fracción / Paraje (siempre, pero disabled por defecto) -->
          <div class="field">
            <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.3rem">
              <label id="lbl_fraccion" style="margin:0">{inmueble?.tipo_inmueble === 'rural' ? 'Paraje' : 'Fracción'}</label>
              <label style="display:flex;align-items:center;gap:5px;font-size:0.78rem;font-weight:400;cursor:pointer;color:var(--color-text-secondary)">
                <input type="checkbox" id="chk_fraccion" style="width:13px;height:13px"
                  checked={!!(inmueble?.fraccion)} />
                Habilitar
              </label>
            </div>
            <input class="input" name="fraccion" id="input_fraccion"
              value={inmueble?.fraccion ?? ''}
              disabled={!inmueble?.fraccion}
              placeholder="Opcional" />
          </div>
        </div>

        <!-- Inscripción Municipal (excepcional) -->
        <div class="section-label" style="margin-top:0.5rem">Inscripción Municipal</div>
        <div style="margin-bottom:1.25rem">
          <label style="display:flex;align-items:center;gap:8px;font-weight:400;cursor:pointer;font-size:0.9rem">
            <input type="checkbox" id="chk_inscripcion_municipal"
              style="width:15px;height:15px;accent-color:var(--color-primary)"
              checked={!!(inmueble?.matricula_municipal)} />
            Habilitar inscripción municipal (caso excepcional)
          </label>
          <p style="font-size:0.78rem;color:var(--color-text-secondary);margin:0.2rem 0 0.6rem 24px">
            La mayoría de los inmuebles tienen matrícula. Solo habilitar en casos especiales.
          </p>
          <div id="campo_inscripcion_municipal" class="field" style="margin-bottom:0">
            <label>Nº Inscripción Municipal</label>
            <input class="input" id="input_inscripcion_municipal" name="matricula_municipal"
              value={inmueble?.matricula_municipal ?? ''}
              disabled={!inmueble?.matricula_municipal} />
          </div>
        </div>

        <!-- Inscripción Registro de la Propiedad -->
        <div class="section-label" style="margin-top:0.5rem">Inscripción en Registro de la Propiedad Inmueble</div>
        <input type="hidden" name="tipo_inscripcion_registro" id="tipo_inscripcion_registro_input"
          value={(inmueble as any)?.tipo_inscripcion_registro ?? 'matricula'} />
        <div style="display:flex;gap:1.5rem;margin-bottom:1rem">
          <label style="display:flex;align-items:center;gap:7px;font-weight:400;cursor:pointer">
            <input type="radio" name="_inscripcion_radio" id="radio_matricula" value="matricula"
              checked={(inmueble as any)?.tipo_inscripcion_registro !== 'tomo'} />
            Matrícula
          </label>
          <label style="display:flex;align-items:center;gap:7px;font-weight:400;cursor:pointer">
            <input type="radio" name="_inscripcion_radio" id="radio_tomo" value="tomo"
              checked={(inmueble as any)?.tipo_inscripcion_registro === 'tomo'} />
            Tomo / Folio / Finca / Año
          </label>
        </div>

        <!-- Matrícula (modo por defecto) -->
        <div id="grupo_matricula_registro" class="form-grid form-grid-2"
          style={(inmueble as any)?.tipo_inscripcion_registro === 'tomo' ? 'display:none;margin-bottom:1rem' : 'margin-bottom:1rem'}>
          <div class="field">
            <label>Nº Matrícula</label>
            <input class="input" name="matricula_registro" id="input_matricula_registro"
              value={inmueble?.matricula_registro ?? ''}
              disabled={(inmueble as any)?.tipo_inscripcion_registro === 'tomo'} />
          </div>
          <div class="field">
            <label>Año</label>
            <input class="input" name="registro_anio" id="input_matricula_anio"
              value={(inmueble as any)?.registro_anio ?? ''}
              disabled={(inmueble as any)?.tipo_inscripcion_registro === 'tomo'} />
          </div>
        </div>

        <!-- Tomo / Folio / Finca / Año -->
        <div id="grupo_tomo_folio" class="form-grid form-grid-2"
          style={(inmueble as any)?.tipo_inscripcion_registro !== 'tomo' ? 'display:none;margin-bottom:1rem' : 'margin-bottom:1rem'}>
          <div class="field">
            <label>Tomo</label>
            <input class="input" name="registro_tomo" id="input_registro_tomo"
              value={(inmueble as any)?.registro_tomo ?? ''}
              disabled={(inmueble as any)?.tipo_inscripcion_registro !== 'tomo'} />
          </div>
          <div class="field">
            <label>Folio</label>
            <input class="input" name="registro_folio" id="input_registro_folio"
              value={(inmueble as any)?.registro_folio ?? ''}
              disabled={(inmueble as any)?.tipo_inscripcion_registro !== 'tomo'} />
          </div>
          <div class="field">
            <label>Finca</label>
            <input class="input" name="registro_finca" id="input_registro_finca"
              value={(inmueble as any)?.registro_finca ?? ''}
              disabled={(inmueble as any)?.tipo_inscripcion_registro !== 'tomo'} />
          </div>
          <div class="field">
            <label>Año</label>
            <input class="input" name="registro_anio" id="input_registro_anio"
              value={(inmueble as any)?.registro_anio ?? ''}
              disabled={(inmueble as any)?.tipo_inscripcion_registro !== 'tomo'} />
          </div>
        </div>

        <div style="margin-bottom:1.25rem">
          <label style="display:flex;align-items:center;gap:8px;font-weight:400;cursor:pointer;font-size:0.9rem">
            <input type="checkbox" name="inscripcion_mayor_extension" id="chk_mayor_extension"
              style="width:15px;height:15px;accent-color:var(--color-primary)"
              checked={(inmueble as any)?.inscripcion_mayor_extension === true} />
            La inscripción anterior es en mayor extensión
          </label>
          <p style="font-size:0.78rem;color:var(--color-text-secondary);margin:0.2rem 0 0 24px">
            Marcar cuando la escritura original corresponde a una parcela de mayor superficie de la que se mide.
          </p>
        </div>

        <!-- Referencias para notificación a linderos -->
        <div class="section-label" style="margin-top:0.5rem">Referencias para notificación a linderos</div>
        <div class="form-grid form-grid-2" style="margin-bottom:1rem">
          <div class="field">
            <label>Propietario anterior (a nombre de quien figura)</label>
            <input class="input" name="propietario_anterior" value={(inmueble as any)?.propietario_anterior ?? ''} />
          </div>
          <div class="field">
            <label>Calle de frente</label>
            <input class="input" name="calle_frente" value={(inmueble as any)?.calle_frente ?? ''} />
          </div>
          <div class="field">
            <label>Entre calle</label>
            <input class="input" name="calle_entre1" value={(inmueble as any)?.calle_entre1 ?? ''} />
          </div>
          <div class="field">
            <label>Y calle</label>
            <input class="input" name="calle_entre2" value={(inmueble as any)?.calle_entre2 ?? ''} />
          </div>
        </div>

        <!-- Linderos (citación) -->
        <div class="section-label" style="margin-top:0.5rem">Linderos</div>
        <div class="form-grid form-grid-2" style="margin-bottom:1.5rem">
          <div class="field"><label>Norte</label><input class="input" name="norte_citacion" value={linderos?.norte_citacion ?? ''} /></div>
          <div class="field"><label>Sur</label><input class="input" name="sur_citacion" value={linderos?.sur_citacion ?? ''} /></div>
          <div class="field"><label>Este</label><input class="input" name="este_citacion" value={linderos?.este_citacion ?? ''} /></div>
          <div class="field"><label>Oeste</label><input class="input" name="oeste_citacion" value={linderos?.oeste_citacion ?? ''} /></div>
        </div>

        <!-- Antecedentes técnicos -->
        <div class="field" style="margin-bottom:1.5rem">
          <label>Antecedentes Técnicos — Duplicados de Mensura (GEOSIT)</label>
          <textarea class="input" name="antecedentes_tecnicos" rows="2"
            placeholder="Ej: 3072-K, 3052-K, 3056-K, 3144-K">{(inmueble as any)?.antecedentes_tecnicos ?? ''}</textarea>
          <p style="font-size:0.78rem;color:var(--color-text-secondary);margin:0.35rem 0 0">
            Solo los códigos de duplicados — el Capítulo de Extensión, Límites e Inscripciones arma la oración completa
            ("En el sistema GEOSIT... se hallan los duplicados de Mensura <strong>[esto]</strong> relacionadas a las presentes operaciones.") y los muestra en negrita.
          </p>
        </div>

        <button type="submit" class="btn btn-primary">Guardar inmueble</button>
      </form>
    )}

    <!-- TAB 3: MENSURA -->
    {activeTab === 'mensura' && (
      <div>
        <form method="POST">
          <input type="hidden" name="_action" value="guardar_mensura" />
          <input type="hidden" name="_tab" value="mensura" />

          <div class="section-label">Datos generales</div>
          {exp.tipo_mensura && (
            <div style="background:var(--color-bg);border:1px solid var(--color-border);border-radius:var(--radius-sm);padding:0.5rem 0.75rem;margin-bottom:1rem;font-size:0.85rem;color:var(--color-text-secondary)">
              <span style="font-weight:600;color:var(--color-text)">Tipo de mensura:</span> {exp.tipo_mensura}
              <span style="font-size:0.75rem;margin-left:0.5rem">(se define al crear el expediente)</span>
            </div>
          )}
          <div class="form-grid form-grid-2" style="margin-bottom:1.25rem">
            <div class="field">
              <label>Nº Expediente</label>
              <input class="input" name="numero_expediente" value={exp.numero_expediente ?? ''} />
            </div>
            <div class="field">
              <label>Fecha de mensura</label>
              <input class="input" type="date" name="fecha_mensura" value={exp.fecha_inicio ?? ''} />
            </div>
            <div class="field">
              <label>Hora de mensura</label>
              <input class="input" type="time" name="hora_mensura" value={(exp as any).hora_mensura ?? ''} />
            </div>
            <div class="field">
              <label>Área de Catastro (ubicación actual del expediente)</label>
              <input class="input" name="area_catastro" value={(exp as any).area_catastro ?? ''} placeholder="Ej: Dirección General de Catastro - Mesa de entradas" />
            </div>
          </div>

          <div class="section-label">Polígono(s)</div>
          <input type="hidden" name="cantidad_poligonos" value={poligonosParaUI.length} />

          <div id="poligonos_cards">
            {poligonosParaUI.map((pol: any, idx: number) => {
              const desde = pol?.parcela_desde ?? (idx + 1)
              const hasta = pol?.parcela_hasta ?? desde
              return (
                <div class="poligono-card" id={`poligono_card_${idx}`}>
                  <div class="poligono-card-header">
                    <span class="poligono-card-label" id={`poligono_label_${idx}`}>
                      {desde === hasta ? `Parcela ${desde}` : `Parcelas ${desde} a ${hasta}`}
                    </span>
                    {poligonosParaUI.length > 1 && (
                      <button type="submit" name="eliminar_pol_id" value={pol?.id ?? ''}
                        formnovalidate class="btn btn-danger btn-sm">
                        Eliminar
                      </button>
                    )}
                  </div>

                  <input type="hidden" name={`pol_${idx}_id`} value={pol?.id ?? ''} />

                  <div class="form-grid form-grid-2" style="margin-bottom:0.75rem">
                    <div class="field">
                      <label>Nº Parcela (desde)</label>
                      <input class="input" type="number" min="1" name={`pol_${idx}_parcela_desde`}
                        value={desde} data-pol-desde={idx} />
                    </div>
                    <div class="field">
                      <label>Nº Parcela (hasta) <span style="font-weight:400;font-size:0.78rem;color:var(--color-text-secondary)">(si agrupa varias con igual medida)</span></label>
                      <input class="input" type="number" min="1" name={`pol_${idx}_parcela_hasta`}
                        value={hasta} data-pol-hasta={idx} />
                    </div>
                  </div>

                  <div class="form-grid form-grid-2" style="margin-bottom:1rem">
                    <div class="field" style="grid-column:1/-1;margin-bottom:0">
                      <label style="display:flex;align-items:center;gap:8px;font-weight:400;cursor:pointer;font-size:0.85rem">
                        <input type="checkbox" id={`chk_superficie_manual_${idx}`}
                          style="width:14px;height:14px;accent-color:var(--color-primary)"
                          checked={(pol as any)?.superficie_manual === true} />
                        Corregir superficie manualmente
                      </label>
                      <p style="font-size:0.76rem;color:var(--color-text-secondary);margin:0.15rem 0 0.6rem 22px">
                        Por defecto se calcula sola a partir de los lados y ángulos cargados abajo.
                      </p>
                      <input type="hidden" name={`pol_${idx}_superficie_manual`} id={`superficie_manual_${idx}`}
                        value={(pol as any)?.superficie_manual === true ? 'on' : ''} />
                    </div>
                    {inmueble?.tipo_inmueble === 'rural' ? (
                      <>
                        <div class="field">
                          <label>Superficie — Hectáreas</label>
                          <input class="input" type="number" step="1" min="0" name={`pol_${idx}_superficie_ha`} id={`sup_ha_${idx}`}
                            value={pol?.superficie_m2 != null ? Math.floor((pol.superficie_m2 as number) / 10000) : ''}
                            disabled={(pol as any)?.superficie_manual !== true} />
                        </div>
                        <div class="field">
                          <label>Áreas</label>
                          <input class="input" type="number" step="1" min="0" max="99" name={`pol_${idx}_superficie_a`} id={`sup_a_${idx}`}
                            value={pol?.superficie_m2 != null ? Math.floor(((pol.superficie_m2 as number) % 10000) / 100) : ''}
                            disabled={(pol as any)?.superficie_manual !== true} />
                        </div>
                        <div class="field">
                          <label>Centiáreas</label>
                          <input class="input" type="number" step="0.01" min="0" max="99.99" name={`pol_${idx}_superficie_ca`} id={`sup_ca_${idx}`}
                            value={pol?.superficie_m2 != null ? Number(((pol.superficie_m2 as number) % 100).toFixed(2)) : ''}
                            disabled={(pol as any)?.superficie_manual !== true} />
                        </div>
                        <div class="field" style="grid-column:1/-1">
                          <label>Superficie en letras <span style="font-weight:400;font-size:0.78rem;color:var(--color-text-secondary)">(auto)</span></label>
                          <input class="input" name={`pol_${idx}_superficie_letras`} id={`superficie_letras_${idx}`}
                            value={pol?.superficie_letras ?? ''} readonly tabindex="-1"
                            style="color:var(--color-primary);font-weight:600;background:var(--color-border);cursor:default" />
                        </div>
                      </>
                    ) : (
                      <>
                        <div class="field">
                          <label>Superficie total (m²)</label>
                          <input class="input" type="number" step="0.0001" name={`pol_${idx}_superficie_m2`} id={`superficie_m2_${idx}`}
                            value={pol?.superficie_m2 ?? ''}
                            disabled={(pol as any)?.superficie_manual !== true} />
                        </div>
                        <div class="field">
                          <label>Superficie en letras <span style="font-weight:400;font-size:0.78rem;color:var(--color-text-secondary)">(auto)</span></label>
                          <input class="input" name={`pol_${idx}_superficie_letras`} id={`superficie_letras_${idx}`}
                            value={pol?.superficie_letras ?? ''} readonly tabindex="-1"
                            style="color:var(--color-primary);font-weight:600;background:var(--color-border);cursor:default" />
                        </div>
                      </>
                    )}
                    <div class="field">
                      <label>Cantidad de lados</label>
                      <input class="input" type="number" name={`pol_${idx}_cantidad_lados`} id={`cant_lados_${idx}`} value={pol?.cantidad_lados ?? ''} min="0" />
                    </div>
                    <div class="field">
                      <label>Cantidad de ángulos</label>
                      <input class="input" type="number" name={`pol_${idx}_cantidad_angulos`} id={`cant_angulos_${idx}`} value={pol?.cantidad_angulos ?? ''} min="0" />
                    </div>
                  </div>

                  <div id={`lados_section_${idx}`} style="margin-top:1rem;display:none">
                    <div class="section-label">Lados del polígono</div>
                    <div class="lados-header">
                      <span>Lado</span><span>Longitud (m)</span><span>En letras</span>
                    </div>
                    <div id={`lados_rows_${idx}`}></div>
                    {pol?.cantidad_lados > 0 && (
                      <p class="lados-suma" id={`lados_suma_${idx}`}></p>
                    )}
                  </div>

                  <div id={`angulos_section_${idx}`} style="margin-top:1.25rem;display:none">
                    <div class="section-label">Ángulos del polígono</div>
                    <div class="lados-header">
                      <span>Ángulo</span><span>Valor (GG.MMSS)</span><span>En letras</span>
                    </div>
                    <div id={`angulos_rows_${idx}`}></div>
                    <div id={`angulos_visor_${idx}`} style="display:none;margin-top:0.75rem"></div>
                  </div>
                </div>
              )
            })}
          </div>

          <div style="margin:0.25rem 0 1.25rem">
            <button type="submit" name="_agregar_poligono" value="1" formnovalidate class="btn btn-secondary">
              + Agregar polígono
            </button>
          </div>

          <div id="error_sumatoria" style="display:none;color:#EF4444;font-size:0.85rem;font-weight:500;background:#FEF2F2;border:1px solid #FECACA;border-radius:6px;padding:0.6rem 0.875rem;margin-top:1rem"></div>
          <button type="submit" class="btn btn-primary" style="margin-bottom:1.5rem;margin-top:0.75rem">Guardar mensura</button>
        </form>

        <form method="POST">
          <input type="hidden" name="_action" value="guardar_linderos" />
          <input type="hidden" name="_tab" value="mensura" />

          <div class="section-label">Linderos</div>
          <div style="background:var(--color-bg);border:1px solid var(--color-border);border-radius:var(--radius-sm);padding:0.5rem 0.75rem;margin-bottom:1rem;font-size:0.85rem;color:var(--color-text-secondary)">
            Por defecto son los mismos linderos cargados en la pestaña <strong>Inmueble</strong>. Si al hacer la mensura encontrás que cambió alguno, destildá la opción de abajo para corregirlo acá.
          </div>
          <div class="form-grid form-grid-2" style="margin-bottom:1rem">
            {(['norte', 'sur', 'este', 'oeste'] as const).map(dir => {
              const citacionVal = (linderos as any)?.[`${dir}_citacion`] ?? ''
              const mensuraVal = (linderos as any)?.[`${dir}_mensura`] ?? ''
              const auto = linderos?.linderos_iguales !== false
              const valorInicial = auto ? citacionVal : mensuraVal
              const label = dir.charAt(0).toUpperCase() + dir.slice(1)
              return (
                <div class="field">
                  <label>{label}</label>
                  <input class="input" id={`lind_${dir}_visible`} value={valorInicial} disabled={auto}
                    data-citacion={citacionVal} />
                  <input type="hidden" name={`${dir}_mensura`} id={`lind_${dir}_hidden`} value={valorInicial} />
                </div>
              )
            })}
          </div>

          <label style="display:flex;align-items:center;gap:8px;margin-bottom:1rem;font-weight:400">
            <input type="checkbox" name="linderos_iguales" id="lind_iguales" checked={linderos?.linderos_iguales !== false} />
            Usar los mismos linderos que en la citación (Tab Inmueble)
          </label>

          <button type="submit" class="btn btn-primary">Guardar linderos</button>
        </form>
      </div>
    )}

    <!-- TAB 4: TESTIGOS -->
    {activeTab === 'testigos' && (
      <div>
        <h3 style="margin-bottom:1rem">Testigos del expediente</h3>
        {(expTestigos ?? []).length > 0 && (
          <div style="margin-bottom:1.5rem">
            <table>
              <thead><tr><th>Nombre</th><th>DNI</th><th>Domicilio</th><th></th></tr></thead>
              <tbody>
                {expTestigos!.map((et: any) => (
                  <>
                    <tr>
                      <td>{et.testigos?.apellido}, {et.testigos?.nombre}</td>
                      <td>{et.testigos?.dni}</td>
                      <td>{et.testigos?.domicilio}</td>
                      <td style="display:flex;gap:0.5rem">
                        <details>
                          <summary class="btn btn-secondary btn-sm" style="display:inline-block;cursor:pointer">Editar</summary>
                          <form method="POST" style="margin-top:0.75rem;min-width:340px">
                            <input type="hidden" name="_action" value="editar_testigo" />
                            <input type="hidden" name="_tab" value="testigos" />
                            <input type="hidden" name="testigo_id" value={et.testigos?.id} />
                            <div class="form-grid form-grid-2">
                              <div class="field"><label>Nombre</label><input class="input" name="t_nombre" value={et.testigos?.nombre ?? ''} required /></div>
                              <div class="field"><label>Apellido</label><input class="input" name="t_apellido" value={et.testigos?.apellido ?? ''} required /></div>
                              <div class="field"><label>DNI</label><input class="input" name="t_dni" value={et.testigos?.dni ?? ''} /></div>
                              <div class="field"><label>Domicilio</label><input class="input" name="t_domicilio" value={et.testigos?.domicilio ?? ''} /></div>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm" style="margin-top:0.6rem">Guardar cambios</button>
                          </form>
                        </details>
                        <form method="POST" style="display:inline">
                          <input type="hidden" name="_action" value="quitar_testigo" />
                          <input type="hidden" name="_tab" value="testigos" />
                          <input type="hidden" name="exp_testigo_id" value={et.id} />
                          <button type="submit" class="btn btn-danger btn-sm">Quitar</button>
                        </form>
                      </td>
                    </tr>
                  </>
                ))}
              </tbody>
            </table>
          </div>
        )}

        <details class="form-section">
          <summary>Buscar testigo existente</summary>
          <form method="POST" style="margin-top:1rem">
            <input type="hidden" name="_action" value="agregar_testigo" />
            <input type="hidden" name="_tab" value="testigos" />
            <div class="field" style="max-width:360px">
              <label>Testigo</label>
              <select class="input" name="testigo_id">
                <option value="">Seleccionar...</option>
                {(testigosAll ?? []).map((t: any) => (
                  <option value={t.id}>{t.apellido}, {t.nombre} — DNI {t.dni}</option>
                ))}
              </select>
            </div>
            <button type="submit" class="btn btn-primary" style="margin-top:0.75rem">Agregar testigo</button>
          </form>
        </details>

        <details class="form-section" style="margin-top:1rem">
          <summary>Crear nuevo testigo</summary>
          <form method="POST" style="margin-top:1rem">
            <input type="hidden" name="_action" value="crear_testigo" />
            <input type="hidden" name="_tab" value="testigos" />
            <div class="form-grid form-grid-2">
              <div class="field"><label>Nombre</label><input class="input" name="t_nombre" required /></div>
              <div class="field"><label>Apellido</label><input class="input" name="t_apellido" required /></div>
              <div class="field"><label>DNI</label><input class="input" name="t_dni" /></div>
              <div class="field"><label>Domicilio</label><input class="input" name="t_domicilio" /></div>
            </div>
            <button type="submit" class="btn btn-primary" style="margin-top:0.75rem">Crear y agregar</button>
          </form>
        </details>
      </div>
    )}

    <!-- TAB 5: DOCUMENTOS -->
    {activeTab === 'documentos' && (
      <div>
        <h3 style="margin-bottom:0.25rem">Generar documentos</h3>
        <p style="font-size:0.875rem;color:var(--color-text-secondary);margin-bottom:1.5rem">
          Seleccioná los documentos a generar para este expediente.
        </p>

        <form method="POST" action="/api/documentos/generar" id="form_generar_seleccionados">
          <input type="hidden" name="expediente_id" value={id} />

          <div class="section-label" style="margin-top:0">Contenido básico del expediente</div>
          <div style="display:flex;flex-direction:column;gap:0.625rem;margin-bottom:1.25rem">
            {[
              { value: 'caratula',               label: 'Carátula' },
              { value: 'nota_elevacion',          label: 'Nota de Elevación a la Directora' },
              { value: 'documento_identidad',     label: 'Fotocopia del DNI del/los Comitente/s' },
              { value: 'capitulo_ubicacion',      label: 'Capítulo de Extensión, Límites e Inscripciones' },
              { value: 'citacion_linderos',       label: 'Notificación a Linderos y Autoridades' },
              { value: 'acta_mensura',            label: 'Acta de Mensura y Amojonamiento' },
              { value: 'acta_ausencia_linderos',  label: 'Acta de Ausencia de Linderos y Autoridades' },
              { value: 'memoria_mensura',         label: 'Memoria de Mensura' },
              { value: 'planilla_calculos',       label: 'Planilla de Cálculos' },
            ].map(doc => (
              <label style="display:flex;align-items:center;gap:10px;font-weight:400;cursor:pointer">
                <input type="checkbox" name="tipos[]" value={doc.value} />
                {doc.label}
              </label>
            ))}
          </div>

          <div class="section-label">Declaraciones juradas por parcela</div>
          <div style="display:flex;flex-direction:column;gap:0.625rem;margin-bottom:1.5rem">
            {!inmueble && (
              <p style="font-size:0.85rem;color:var(--color-text-secondary)">
                Completá primero la Tab 2 Inmueble — el tipo de formulario (Urbano o Rural) se determina según el tipo de inmueble cargado ahí.
              </p>
            )}
            {inmueble && (inmueble as any).tipo_inmueble !== 'rural' && (
              <label style="display:flex;align-items:center;gap:10px;font-weight:400;cursor:pointer">
                <input type="checkbox" name="tipos[]" value="formulario_u" />
                Formulario "U" — Declaración Jurada (Inmueble urbano)
              </label>
            )}
            {inmueble && (inmueble as any).tipo_inmueble === 'rural' && (
              <label style="display:flex;align-items:center;gap:10px;font-weight:400;cursor:pointer">
                <input type="checkbox" name="tipos[]" value="formulario_sor" />
                Formulario "SOR" — Declaración Jurada (Suburbano o rural)
              </label>
            )}
            <label style="display:flex;align-items:center;gap:10px;font-weight:400;cursor:pointer">
              <input type="checkbox" name="tipos[]" value="formulario_e1" />
              Formulario "E1" — Con construcciones
            </label>
          </div>

          <div class="botones-generar-fila">
            <button type="submit" class="btn btn-primary">Generar seleccionados</button>
            <button type="submit" form="form_expediente_completo" class="btn btn-secondary">Generar expediente completo (PDF único)</button>
          </div>
        </form>

        <form method="POST" action="/api/documentos/generar" id="form_expediente_completo">
          <input type="hidden" name="expediente_id" value={id} />
          <input type="hidden" name="tipos[]" value="expediente_completo" />
        </form>

        <div style="margin-top:2rem" id="documentos_section">
          <h4 style="margin-bottom:0.75rem" id="documentos_titulo">Documentos generados {documentosCount ? `(${documentosCount})` : ''}</h4>
          <table>
            <thead><tr><th>Tipo</th><th>Fecha y hora</th><th>Estado</th><th>Descarga</th><th></th></tr></thead>
            <tbody id="documentos_tbody">
              {(documentos ?? []).length === 0 && (
                <tr id="documentos_vacio">
                  <td colspan="5" style="text-align:center;color:var(--color-text-secondary);padding:1.5rem">
                    Todavía no se generó ningún documento.
                  </td>
                </tr>
              )}
              {(documentos ?? []).map((doc: any) => (
                <tr data-doc-row>
                  <td style="text-transform:capitalize">{doc.tipo_documento.replace(/_/g,' ')}</td>
                  <td>{new Date(doc.generado_at).toLocaleString('es-AR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' })}</td>
                  <td>
                    {doc.estado === 'error_storage'
                      ? <span class="badge badge-borrador">sin archivo</span>
                      : <span class="badge badge-finalizado">generado</span>
                    }
                  </td>
                  <td>
                    {doc.storage_path
                      ? <a href={`/api/documentos/descargar?path=${doc.storage_path}`} class="btn btn-secondary btn-sm btn-descargar-pdf" data-tipo={doc.tipo_documento.replace(/_/g, ' ')}>Descargar</a>
                      : <span style="color:var(--color-muted);font-size:0.8125rem">No disponible</span>
                    }
                  </td>
                  <td>
                    <form class="form-eliminar-documento" style="display:inline"
                      data-tipo={doc.tipo_documento.replace(/_/g, ' ')}
                      data-fecha={new Date(doc.generado_at).toLocaleString('es-AR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' })}
                      data-documento-id={doc.id}>
                      <button type="button" class="btn btn-danger btn-sm btn-eliminar-doc-trigger">Eliminar</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>

          {docTotalPages > 1 && (
            <div style="display:flex;gap:0.5rem;align-items:center;justify-content:center;margin-top:1rem">
              <a href={`?tab=documentos&docpag=${Math.max(1, docPage - 1)}`}
                class={`btn btn-secondary btn-sm ${docPage <= 1 ? 'btn-disabled' : ''}`}
                aria-disabled={docPage <= 1}>← Anterior</a>
              <span style="font-size:0.875rem;color:var(--color-text-secondary)">Página {docPage} de {docTotalPages}</span>
              <a href={`?tab=documentos&docpag=${Math.min(docTotalPages, docPage + 1)}`}
                class={`btn btn-secondary btn-sm ${docPage >= docTotalPages ? 'btn-disabled' : ''}`}
                aria-disabled={docPage >= docTotalPages}>Siguiente →</a>
            </div>
          )}
        </div>
      </div>
    )}

    <!-- TAB 6: DDJJ -->
    {activeTab === 'ddjj' && (
      <div>
        <h3 style="margin-bottom:0.25rem">Declaración Jurada — Formulario {inmueble?.tipo_inmueble === 'rural' ? 'SOR' : 'U'}</h3>
        <p style="font-size:0.875rem;color:var(--color-text-secondary);margin-bottom:1.5rem">
          Datos adicionales que pide Catastro para la Declaración Jurada, además de lo ya cargado en Inmueble y Comitente.
        </p>

        {!inmueble && (
          <div class="alert alert-error" style="margin-bottom:1rem">Completá primero la Tab 2 Inmueble.</div>
        )}

        <form method="POST">
          <input type="hidden" name="_action" value="guardar_ddjj" />
          <input type="hidden" name="_tab" value="ddjj" />

          <div class="section-label">Datos del inmueble</div>
          <div class="form-grid form-grid-2" style="margin-bottom:1.25rem">
            <div class="field">
              <label style="display:flex;align-items:center;gap:8px;font-weight:400;cursor:pointer">
                <input type="checkbox" name="agua_corriente" checked={(inmueble as any)?.agua_corriente === true} />
