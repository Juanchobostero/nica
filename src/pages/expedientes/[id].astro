.modal-info { border:1px solid var(--color-border); border-radius:var(--radius-sm); margin-bottom:1rem; overflow:hidden; }
.modal-info-row { display:flex; justify-content:space-between; gap:0.75rem; padding:0.45rem 0.75rem; font-size:0.85rem; }
.modal-info-row:not(:last-child) { border-bottom:1px solid var(--color-border); }
.modal-info-row span { color:var(--color-text-secondary); }
.modal-info-row strong { color:var(--color-text); font-weight:600; text-align:right; }
.validacion-doc { margin-bottom:0.75rem; }
.validacion-doc-titulo { font-size:0.85rem; font-weight:700; color:var(--color-text); margin-bottom:0.3rem; }
.validacion-item { font-size:0.82rem; color:#92400E; display:flex; align-items:flex-start; gap:0.4rem; padding:0.15rem 0; }
.modal-note {
  font-size:0.8rem; color:var(--color-text-secondary); background:var(--color-bg);
  border-radius:var(--radius-sm); padding:0.6rem 0.75rem; margin-bottom:1.25rem;
}
.modal-actions { display:flex; justify-content:flex-end; gap:0.6rem; }

@keyframes modal-fade-in { from { opacity:0; } to { opacity:1; } }
@keyframes modal-pop-in { from { opacity:0; transform:scale(0.96) translateY(4px); } to { opacity:1; transform:scale(1) translateY(0); } }
</style>
