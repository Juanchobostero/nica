.back-link:hover { color:var(--color-primary); }
.page-header h2 { font-size:1.5rem; display:flex; align-items:center; }
.section-label { font-weight:600; font-size:0.8125rem; color:var(--color-primary); text-transform:uppercase; letter-spacing:0.04em; margin-bottom:0.75rem; margin-top:0.5rem; }
