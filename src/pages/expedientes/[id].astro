<script define:vars={{
  poligonosVars:              poligonosVarsForScript,
  tipoInmuebleInicial:        inmueble?.tipo_inmueble ?? 'urbano',
  tipoInscripcionInicial:     (inmueble as any)?.tipo_inscripcion_registro ?? 'matricula',
  fraccionTieneValor:         !!(inmueble?.fraccion),
  inscripcionMunTieneValor:   !!(inmueble?.matricula_municipal),
  esRuralInicial:             inmueble?.tipo_inmueble === 'rural',
  datosValidacion: datosValidacion,
}}>
  // Expuesto en window: este script es inline (define:vars), pero el de "generar documentos"
  // se procesa como módulo aparte y no comparte el scope global con este, así que no puede
  // leer `datosValidacion` directamente — hay que colgarlo de window.
  window.datosValidacion = datosValidacion

  // Linderos: si "iguales" está tildado, los 4 campos de mensura quedan deshabilitados
  // y muestran el valor de citación; si se destilda, se habilitan para corregir a mano.
  const lindChk = document.getElementById('lind_iguales')
  const LIND_DIRS = ['norte', 'sur', 'este', 'oeste']
  function aplicarModoLinderos(auto) {
    LIND_DIRS.forEach(d => {
      const visible = document.getElementById(`lind_${d}_visible`)
      const hidden  = document.getElementById(`lind_${d}_hidden`)
      if (!visible || !hidden) return
      visible.disabled = auto
      if (auto) {
        visible.value = visible.dataset.citacion || ''
        hidden.value = visible.value
      }
    })
  }
  if (lindChk) {
    lindChk.addEventListener('change', () => aplicarModoLinderos(lindChk.checked))
    LIND_DIRS.forEach(d => {
      const visible = document.getElementById(`lind_${d}_visible`)
      const hidden  = document.getElementById(`lind_${d}_hidden`)
      if (visible && hidden) visible.addEventListener('input', () => { hidden.value = visible.value })
    })
  }

  // ── Helpers compartidos de conversión numérica ──────────────────────────
  const UNIDADES = ['', 'UN', 'DOS', 'TRES', 'CUATRO', 'CINCO', 'SEIS', 'SIETE', 'OCHO', 'NUEVE',
    'DIEZ', 'ONCE', 'DOCE', 'TRECE', 'CATORCE', 'QUINCE', 'DIECISÉIS', 'DIECISIETE', 'DIECIOCHO', 'DIECINUEVE',
    'VEINTE', 'VEINTIÚN', 'VEINTIDÓS', 'VEINTITRÉS', 'VEINTICUATRO', 'VEINTICINCO', 'VEINTISÉIS',
    'VEINTISIETE', 'VEINTIOCHO', 'VEINTINUEVE']
  const DECENAS  = ['', 'DIEZ', 'VEINTE', 'TREINTA', 'CUARENTA', 'CINCUENTA', 'SESENTA', 'SETENTA', 'OCHENTA', 'NOVENTA']
  const CENTENAS = ['', 'CIENTO', 'DOSCIENTOS', 'TRESCIENTOS', 'CUATROCIENTOS', 'QUINIENTOS',
    'SEISCIENTOS', 'SETECIENTOS', 'OCHOCIENTOS', 'NOVECIENTOS']

  function menorMil(n) {
    if (n === 0) return ''
    if (n === 100) return 'CIEN'
    let r = ''
    if (n >= 100) { r = CENTENAS[Math.floor(n / 100)]; n %= 100 }
    if (n >= 30) {
      r += (r ? ' ' : '') + DECENAS[Math.floor(n / 10)]
      if (n % 10) r += ' Y ' + UNIDADES[n % 10]
    } else if (n > 0) {
      r += (r ? ' ' : '') + UNIDADES[n]
    }
    return r
  }

  function convertir(n) {
    if (n === 0) return 'CERO'
    if (n >= 1000) {
      const miles = Math.floor(n / 1000)
      let r = miles === 1 ? 'MIL' : menorMil(miles) + ' MIL'
      const resto = n % 1000
      if (resto) r += ' ' + menorMil(resto)
      return r
    }
    return menorMil(n)
  }

  // ── Conversión metros → letras ──────────────────────────────────────────
  function numeroALetras(valor) {
    if (valor === '' || valor === null || isNaN(parseFloat(valor))) return ''
    const num = parseFloat(valor)
    const metros = Math.floor(num)
    const centimetros = Math.round((num - metros) * 100)
    let texto = convertir(metros) + (metros === 1 ? ' METRO' : ' METROS')
    if (centimetros > 0)
      texto += ' CON ' + convertir(centimetros) + (centimetros === 1 ? ' CENTÍMETRO' : ' CENTÍMETROS')
    return texto
  }

  // ── Conversión GG.MMSS → partes y letras ───────────────────────────────
  function parsearAngulo(valor) {
    if (!valor) return null
    const [gradosPart, decimalPart = ''] = String(valor).split('.')
    const decStr = decimalPart.padEnd(4, '0')
    return {
      grados:   parseInt(gradosPart)              || 0,
      minutos:  parseInt(decStr.substring(0, 2))  || 0,
      segundos: parseInt(decStr.substring(2, 4))  || 0,
    }
  }

  function anguloALetras(valor) {
    const p = parsearAngulo(valor)
    if (!p) return ''
    let texto = convertir(p.grados) + (p.grados === 1 ? ' GRADO' : ' GRADOS')
    texto += ' ' + convertir(p.minutos) + (p.minutos === 1 ? ' MINUTO' : ' MINUTOS')
    if (p.segundos > 0)
      texto += ' ' + convertir(p.segundos) + (p.segundos === 1 ? ' SEGUNDO' : ' SEGUNDOS')
    return texto
  }

  function formatearValorAngulo(g, m, s) {
    if (g == null) return ''
    const mm = String(parseInt(m ?? 0)).padStart(2, '0')
    const ss = String(parseInt(s ?? 0)).padStart(2, '0')
    return `${g}.${mm}${ss}`
  }

  // ── Lados / Ángulos / numeración por polígono (card) ────────────────────
  // Cada card de polígono/parcela tiene sus propios elementos con id sufijado
  // por índice (ej. cant_lados_0, lados_rows_0...), así que estas funciones
  // toman `idx` y buscan siempre dentro de ese scope.

  function actualizarLabelPoligono(idx) {
    const desdeInput = document.querySelector(`[data-pol-desde="${idx}"]`)
    const hastaInput  = document.querySelector(`[data-pol-hasta="${idx}"]`)
    const label = document.getElementById(`poligono_label_${idx}`)
    if (!desdeInput || !hastaInput || !label) return
    const desde = parseInt(desdeInput.value) || (idx + 1)
    const hasta = parseInt(hastaInput.value) || desde
    label.textContent = desde === hasta ? `Parcela ${desde}` : `Parcelas ${desde} a ${hasta}`
  }

  function svgAngulos(datos, totalSeg) {
    if (!datos.length || totalSeg === 0) return ''
    const SZ = 124, CX = 62, OY = 108, RAY = 58
    const COLS = ['#1B2E5E','#253E80','#2E4EA1','#3B5EC3','#4A72D9','#5A86E8']
    const toR  = d => d * Math.PI / 180
    const px   = a => CX + RAY * Math.cos(toR(a))
    const py   = a => OY - RAY * Math.sin(toR(a))

    const totalDeg = totalSeg / 3600
    // Scale so visual span = min(actual, 130°), but min 30° so it's always visible
    const visDeg = Math.max(30, Math.min(totalDeg, 130))
    const sc     = visDeg / totalDeg
    const start  = 90 + visDeg / 2   // leftmost ray in math degrees (CCW from +x)

    let sectors = '', rays = '', labels = '', cum = 0

    datos.forEach((d, i) => {
      const deg = (d.grados * 3600 + d.minutos * 60 + d.segundos) / 3600
      const vis = deg * sc
      const a1 = start - cum, a2 = start - cum - vis
      const x1 = px(a1), y1 = py(a1), x2 = px(a2), y2 = py(a2)
      const lg = vis > 180 ? 1 : 0
      // Sector: origin → outer arc → close
      sectors += `<path d="M${CX},${OY} L${x1},${y1} A${RAY},${RAY},0,${lg},1,${x2},${y2} Z" fill="${COLS[i%COLS.length]}"/>`
      // Right boundary ray (separator)
      rays += `<line x1="${CX}" y1="${OY}" x2="${x2}" y2="${y2}" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.8"/>`
      // Label centered in sector
      if (vis > 8) {
        const mA = a1 - vis / 2
        const lr = RAY * 0.6
        labels += `<text x="${CX + lr*Math.cos(toR(mA))}" y="${OY - lr*Math.sin(toR(mA))}" text-anchor="middle" dominant-baseline="middle" fill="white" font-size="10" font-weight="bold" font-family="system-ui,sans-serif">A${d.num}</text>`
      }
      cum += vis
    })
    // Left boundary ray
    rays += `<line x1="${CX}" y1="${OY}" x2="${px(start)}" y2="${py(start)}" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.8"/>`
    // Inner arc indicator
    const ar = 13, lgA = cum > 180 ? 1 : 0
    const arcPath = `M${CX+ar*Math.cos(toR(start))},${OY-ar*Math.sin(toR(start))} A${ar},${ar},0,${lgA},1,${CX+ar*Math.cos(toR(start-cum))},${OY-ar*Math.sin(toR(start-cum))}`
    // Origin dot
    const dot = `<circle cx="${CX}" cy="${OY}" r="3.5" fill="white" stroke="#1B2E5E" stroke-width="1.5"/>`
    const arc = `<path d="${arcPath}" fill="none" stroke="rgba(255,255,255,0.55)" stroke-width="1.5"/>`

    return `<svg width="${SZ}" height="${SZ}" viewBox="0 0 ${SZ} ${SZ}" style="flex-shrink:0;filter:drop-shadow(0 2px 8px rgba(27,46,94,.2))">${sectors}${rays}${arc}${labels}${dot}</svg>`
  }

  // Guarda { idx, cantAngulosInput, angulosRows } de cada card para poder
  // validar la sumatoria angular de TODAS al hacer submit del formulario.
  const camposSumatoria = []

  // Superficie de la poligonal cerrada (fórmula de Gauss/shoelace sobre coordenadas
  // compensadas por regla de la brújula) — puerto en JS plano de src/lib/poligonal.ts,
  // que es la fuente de verdad (usada también al guardar, del lado del servidor, y en
  // la Planilla de Cálculos). Este script no puede importar TS de proyecto.
  function calcularSuperficieVanilla(ladosVals, angulosVals) {
    const n = Math.max(ladosVals.length, angulosVals.length)
    if (n < 3) return null

    const azimuts = []
    for (let i = 0; i < n; i++) {
      const ang = angulosVals[i] || { grados: 0, minutos: 0, segundos: 0 }
      const angDecimal = ang.grados + ang.minutos / 60 + ang.segundos / 3600
      if (i === 0) azimuts.push(90)
      else {
        const az = azimuts[i - 1] - (180 - angDecimal)
        azimuts.push(((az % 360) + 360) % 360)
      }
    }

    const dx = [], dy = []
    for (let i = 0; i < n; i++) {
      const L = ladosVals[i] || 0
      const rad = (azimuts[i] * Math.PI) / 180
      dx.push(L * Math.cos(rad))
      dy.push(L * Math.sin(rad))
    }
    const sumDX = dx.reduce((a, b) => a + b, 0)
    const sumDY = dy.reduce((a, b) => a + b, 0)
    const totalLength = ladosVals.reduce((a, b) => a + (b || 0), 0)

    const xc = [], yc = []
    let cumXC = 0, cumYC = 0
    for (let i = 0; i < n; i++) {
      const L = ladosVals[i] || 0
      const corrX = totalLength ? -sumDX * (L / totalLength) : 0
      const corrY = totalLength ? -sumDY * (L / totalLength) : 0
      xc.push(cumXC); yc.push(cumYC)
      cumXC += dx[i] + corrX
      cumYC += dy[i] + corrY
    }

    let area = 0
    for (let i = 0; i < n; i++) {
      const j = (i + 1) % n
      area += xc[i] * yc[j] - xc[j] * yc[i]
    }
    return Math.abs(area) / 2
  }

  function initPoligonoCard(idx, datos) {
    const ladosExistentes    = datos.lados
    const cantLadosInicial   = datos.cantLados
    const angulosExistentes  = datos.angulos
    const cantAngulosInicial = datos.cantAngulos

    // ── Lados ───────────────────────────────────────────────────────────
    const cantInput    = document.getElementById(`cant_lados_${idx}`)
    const ladosSection = document.getElementById(`lados_section_${idx}`)
    const ladosRows    = document.getElementById(`lados_rows_${idx}`)
    const ladosSuma    = document.getElementById(`lados_suma_${idx}`)

    function actualizarSuma() {
      const inputs = ladosRows ? ladosRows.querySelectorAll('[data-lado-m]') : []
      let suma = 0
      inputs.forEach(inp => { suma += parseFloat(inp.value) || 0 })
      if (ladosSuma) ladosSuma.textContent = `Suma total: ${suma.toFixed(4)} m`
    }

    function generarFilas(cantidad) {
      if (!ladosRows) return
      ladosRows.innerHTML = ''
      for (let i = 1; i <= cantidad; i++) {
        const exist = ladosExistentes.find(l => l.orden === i) || {}
        const fila = document.createElement('div')
        fila.className = 'lado-fila'
        fila.innerHTML = `
          <span class="lado-num">L${i}</span>
          <input class="input" type="number" step="0.0001" name="pol_${idx}_lado_${i}_valor_m"
            value="${exist.valor_m ?? ''}" placeholder="0.0000" data-lado-m />
          <input class="input" name="pol_${idx}_lado_${i}_valor_letras"
            value="${exist.valor_letras ?? ''}" placeholder="En letras" data-lado-letras readonly tabindex="-1"
            style="color:var(--color-primary);font-weight:600;background:var(--color-border);cursor:default" />
        `
        ladosRows.appendChild(fila)
      }
      ladosRows.querySelectorAll('[data-lado-m]').forEach(inp => {
        inp.addEventListener('input', actualizarSuma)
        inp.addEventListener('input', function() {
          const letrasInput = this.closest('.lado-fila')?.querySelector('[data-lado-letras]')
          if (letrasInput) letrasInput.value = numeroALetras(this.value)
        })
      })
      actualizarSuma()
      if (ladosSection) ladosSection.style.display = cantidad > 0 ? 'block' : 'none'
      if (ladosSuma)    ladosSuma.style.display    = cantidad > 0 ? 'block' : 'none'
    }

    if (cantInput) {
      cantInput.addEventListener('input', () => generarFilas(parseInt(cantInput.value) || 0))
      if (cantLadosInicial > 0) generarFilas(cantLadosInicial)
    }

    // ── Ángulos ─────────────────────────────────────────────────────────
    const cantAngulosInput = document.getElementById(`cant_angulos_${idx}`)
    const angulosSection   = document.getElementById(`angulos_section_${idx}`)
    const angulosRows      = document.getElementById(`angulos_rows_${idx}`)
    const angulosVisor     = document.getElementById(`angulos_visor_${idx}`)

    function actualizarVisor() {
      if (!angulosVisor || !angulosRows) return
      const entradas = angulosRows.querySelectorAll('[data-angulo-valor]')
      const datosAng = []
      entradas.forEach((inp, i) => {
        const p = parsearAngulo(inp.value)
        if (p && (p.grados || p.minutos || p.segundos)) datosAng.push({ num: i + 1, ...p })
      })
      if (!datosAng.length) { angulosVisor.style.display = 'none'; return }

      let totalSeg = 0
      datosAng.forEach(d => { totalSeg += d.grados * 3600 + d.minutos * 60 + d.segundos })
      const sumG = Math.floor(totalSeg / 3600)
      const sumM = Math.floor((totalSeg % 3600) / 60)
      const sumS = totalSeg % 60
      const pad  = n => String(n).padStart(2, '0')

      const listaHtml = datosAng.map(d =>
        `<div style="display:flex;align-items:center;gap:0.45rem">
          <span style="font-weight:700;color:#1B2E5E;font-size:0.78rem;min-width:22px">A${d.num}</span>
          <span style="font-family:monospace;font-size:0.85rem;color:#1A1A2E">${d.grados}° ${pad(d.minutos)}' ${pad(d.segundos)}"</span>
        </div>`
      ).join('')

      angulosVisor.innerHTML = `
        <div style="background:#fff;border:1px solid #E2E8F0;border-radius:8px;padding:0.875rem 1rem;box-shadow:0 1px 4px rgba(27,46,94,.07)">
          <div style="display:flex;align-items:center;gap:1.25rem">
            <div>
              <div style="font-size:0.7rem;font-weight:700;color:#6B7280;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.45rem">Resumen de ángulos</div>
              <div style="display:flex;flex-direction:column;gap:0.2rem;margin-bottom:0.45rem">${listaHtml}</div>
              <div style="font-size:0.82rem;font-weight:600;color:#1B2E5E;border-top:1px solid #E2E8F0;padding-top:0.375rem">∑ = ${sumG}° ${pad(sumM)}' ${pad(sumS)}"</div>
            </div>
            ${svgAngulos(datosAng, totalSeg)}
          </div>
        </div>`
      angulosVisor.style.display = 'block'
    }

    function generarFilasAngulos(cantidad) {
      if (!angulosRows) return
      angulosRows.innerHTML = ''
      for (let i = 1; i <= cantidad; i++) {
        const exist = angulosExistentes.find(a => a.orden === i) || {}
        const valorDisplay = formatearValorAngulo(exist.grados, exist.minutos, exist.segundos)
        const fila = document.createElement('div')
        fila.className = 'lado-fila'
        fila.innerHTML = `
          <span class="lado-num">A${i}</span>
          <input class="input" name="pol_${idx}_angulo_${i}_valor"
            value="${valorDisplay}" placeholder="Ej: 90.3010" data-angulo-valor />
          <input class="input" name="pol_${idx}_angulo_${i}_valor_letras"
            value="${exist.valor_letras ?? ''}" placeholder="En letras" data-angulo-letras readonly tabindex="-1"
            style="color:var(--color-primary);font-weight:600;background:var(--color-border);cursor:default" />
        `
        angulosRows.appendChild(fila)
      }
      angulosRows.querySelectorAll('[data-angulo-valor]').forEach(inp => {
        inp.addEventListener('input', function() {
          const letrasInput = this.closest('.lado-fila')?.querySelector('[data-angulo-letras]')
          if (letrasInput) letrasInput.value = anguloALetras(this.value)
          actualizarVisor()
        })
      })
      actualizarVisor()
      if (angulosSection) angulosSection.style.display = cantidad > 0 ? 'block' : 'none'
    }

    if (cantAngulosInput) {
      cantAngulosInput.addEventListener('input', () => generarFilasAngulos(parseInt(cantAngulosInput.value) || 0))
      if (cantAngulosInicial > 0) generarFilasAngulos(cantAngulosInicial)
    }

    camposSumatoria.push({ idx, cantAngulosInput, angulosRows })

    // ── Superficie autocalculada ─────────────────────────────────────────
    const chkSupManual    = document.getElementById(`chk_superficie_manual_${idx}`)
    const hiddenSupManual = document.getElementById(`superficie_manual_${idx}`)
    const inputM2         = document.getElementById(`superficie_m2_${idx}`)
    const inputHa         = document.getElementById(`sup_ha_${idx}`)
    const inputA          = document.getElementById(`sup_a_${idx}`)
    const inputCa         = document.getElementById(`sup_ca_${idx}`)
    const inputSupLetras  = document.getElementById(`superficie_letras_${idx}`)
    const esRural         = !!inputHa

    function estaEnModoManual() {
      return !!(chkSupManual && chkSupManual.checked)
    }

    function recalcularSuperficie() {
      if (!ladosRows || !angulosRows || estaEnModoManual()) return
      const ladosVals = Array.from(ladosRows.querySelectorAll('[data-lado-m]')).map(inp => parseFloat(inp.value) || 0)
      const angulosVals = Array.from(angulosRows.querySelectorAll('[data-angulo-valor]'))
        .map(inp => parsearAngulo(inp.value) || { grados: 0, minutos: 0, segundos: 0 })
      const areaM2 = calcularSuperficieVanilla(ladosVals, angulosVals)
      if (areaM2 == null) return

      if (esRural) {
        const ha = Math.floor(areaM2 / 10000)
        const a  = Math.floor((areaM2 % 10000) / 100)
        const ca = Number((areaM2 % 100).toFixed(2))
        if (inputHa) inputHa.value = ha
        if (inputA)  inputA.value  = a
        if (inputCa) inputCa.value = ca
        if (inputSupLetras) inputSupLetras.value = superficieHaALetras(ha, a, ca)
      } else {
        if (inputM2) inputM2.value = areaM2.toFixed(4)
        if (inputSupLetras) inputSupLetras.value = superficieALetrasM2(areaM2.toFixed(2))
      }
    }

    function aplicarModoSuperficie(manual) {
      ;[inputM2, inputHa, inputA, inputCa].forEach(el => { if (el) el.disabled = !manual })
      if (hiddenSupManual) hiddenSupManual.value = manual ? 'on' : ''
      if (!manual) recalcularSuperficie()
    }

    if (chkSupManual) chkSupManual.addEventListener('change', () => aplicarModoSuperficie(chkSupManual.checked))
    if (ladosRows)    ladosRows.addEventListener('input', recalcularSuperficie)
    if (angulosRows)  angulosRows.addEventListener('input', recalcularSuperficie)
    recalcularSuperficie()

    // ── Numeración de parcela (label live) ───────────────────────────────
    const desdeInput = document.querySelector(`[data-pol-desde="${idx}"]`)
    const hastaInput  = document.querySelector(`[data-pol-hasta="${idx}"]`)
    if (desdeInput) desdeInput.addEventListener('input', () => actualizarLabelPoligono(idx))
    if (hastaInput)  hastaInput.addEventListener('input', () => actualizarLabelPoligono(idx))
  }

  poligonosVars.forEach((datos, idx) => initPoligonoCard(idx, datos))

  // ── Validación sumatoria angular al submit (todas las cards) ────────────
  const mensuraForm = document.querySelector('input[name="_action"][value="guardar_mensura"]')?.closest('form')
  const errorSumatoria = document.getElementById('error_sumatoria')

  if (mensuraForm) {
    mensuraForm.addEventListener('submit', function(e) {
      if (!errorSumatoria) return
      function fmt(s) {
        return Math.floor(s/3600) + '° ' + String(Math.floor((s%3600)/60)).padStart(2,'0') + "' " + String(s%60).padStart(2,'0') + '"'
      }
      for (const campo of camposSumatoria) {
        const nAngulos = parseInt(campo.cantAngulosInput?.value || '0') || 0
        if (nAngulos < 3 || !campo.angulosRows) continue

        let sumSeg = 0
        campo.angulosRows.querySelectorAll('[data-angulo-valor]').forEach(function(inp) {
          const p = parsearAngulo(inp.value)
          if (p) sumSeg += p.grados * 3600 + p.minutos * 60 + p.segundos
        })
        if (sumSeg === 0) continue

        const expectedSeg = (nAngulos - 2) * 180 * 3600
        if (sumSeg === expectedSeg) continue

        e.preventDefault()
        const diff = sumSeg - expectedSeg
        const sign = diff > 0 ? '+' : '-'
        errorSumatoria.textContent =
          `Polígono ${campo.idx + 1}: la suma de ángulos no coincide con el polígono de ${nAngulos} ángulos.  ` +
          `Actual: ${fmt(sumSeg)}  ·  Esperado: ${fmt(expectedSeg)}  ·  Diferencia: ${sign}${fmt(Math.abs(diff))}`
        errorSumatoria.style.display = 'block'
        errorSumatoria.scrollIntoView({ behavior: 'smooth', block: 'center' })
        return
      }
      errorSumatoria.style.display = 'none'
    })
  }

  // ── Toggle tipo de inmueble (Tab 2) ───────────────────────────────────
  function aplicarTipoInmueble(esRural) {
    var grupoManzana = document.getElementById('grupo_manzana')
    var grupoParcela = document.getElementById('grupo_parcela')
    var grupoSeccion = document.getElementById('grupo_seccion')
    var inputManzana = document.getElementById('input_manzana')
    var inputParcela = document.getElementById('input_parcela')
    var inputSeccion = document.getElementById('input_seccion')
    var lblFraccion  = document.getElementById('lbl_fraccion')

    if (grupoManzana) { grupoManzana.style.display = esRural ? 'none' : ''; if (inputManzana) inputManzana.disabled = esRural }
    if (grupoParcela) { grupoParcela.style.display = esRural ? 'none' : ''; if (inputParcela) inputParcela.disabled = esRural }
    if (grupoSeccion) { grupoSeccion.style.display = esRural ? '' : 'none'; if (inputSeccion) inputSeccion.disabled = !esRural }
    if (lblFraccion) lblFraccion.textContent = esRural ? 'Paraje' : 'Fracción'
  }

  // Aplicar estado inicial (tipo inmueble es solo lectura, no tiene listeners de cambio)
  aplicarTipoInmueble(tipoInmuebleInicial === 'rural')

  // ── Toggle inscripción Registro de la Propiedad ───────────────────────
  function aplicarTipoInscripcion(tipo) {
    var grupoM = document.getElementById('grupo_matricula_registro')
    var grupoT = document.getElementById('grupo_tomo_folio')
    var inputM = document.getElementById('input_matricula_registro')
    var inputMAnio = document.getElementById('input_matricula_anio')
    var hiddenInput = document.getElementById('tipo_inscripcion_registro_input')
    var inputs = [
      document.getElementById('input_registro_tomo'),
      document.getElementById('input_registro_folio'),
      document.getElementById('input_registro_finca'),
      document.getElementById('input_registro_anio'),
    ]
    var esTomo = tipo === 'tomo'
    if (grupoM) grupoM.style.display = esTomo ? 'none' : ''
    if (grupoT) grupoT.style.display = esTomo ? '' : 'none'
    if (inputM) inputM.disabled = esTomo
    if (inputMAnio) inputMAnio.disabled = esTomo
    inputs.forEach(function(inp) { if (inp) inp.disabled = !esTomo })
    if (hiddenInput) hiddenInput.value = tipo
  }

  var radioMatricula = document.getElementById('radio_matricula')
  var radioTomo      = document.getElementById('radio_tomo')
  if (radioMatricula) radioMatricula.addEventListener('change', function() { if (radioMatricula.checked) aplicarTipoInscripcion('matricula') })
  if (radioTomo)      radioTomo.addEventListener('change',      function() { if (radioTomo.checked)      aplicarTipoInscripcion('tomo') })
  aplicarTipoInscripcion(tipoInscripcionInicial)

  // ── Toggle fracción / paraje ───────────────────────────────────────────
  var chkFraccion   = document.getElementById('chk_fraccion')
  var inputFraccion = document.getElementById('input_fraccion')
  if (chkFraccion && inputFraccion) {
    inputFraccion.disabled = !fraccionTieneValor
    chkFraccion.addEventListener('change', function() {
      inputFraccion.disabled = !chkFraccion.checked
      if (!chkFraccion.checked) inputFraccion.value = ''
    })
  }

  // ── Toggle inscripción municipal ───────────────────────────────────────
  var chkMunicipal   = document.getElementById('chk_inscripcion_municipal')
  var inputMunicipal = document.getElementById('input_inscripcion_municipal')
  if (chkMunicipal && inputMunicipal) {
    inputMunicipal.disabled = !inscripcionMunTieneValor
    chkMunicipal.addEventListener('change', function() {
      inputMunicipal.disabled = !chkMunicipal.checked
      if (!chkMunicipal.checked) inputMunicipal.value = ''
    })
  }

  // ── Toggle Formulario E1 (¿tiene construcciones?) ───────────────────────
  var chkConstrucciones = document.getElementById('chk_tiene_construcciones')
  var formE1 = document.getElementById('form_e1')
  if (chkConstrucciones && formE1) {
    chkConstrucciones.addEventListener('change', function() {
      formE1.style.display = chkConstrucciones.checked ? '' : 'none'
    })
  }

  // ── Auto-conversión superficie a letras (Tab 3) ───────────────────────
  function superficieALetrasM2(valor) {
    if (!valor || isNaN(parseFloat(valor))) return ''
    var n = parseFloat(valor)
    var metros = Math.floor(n)
    var cm = Math.round((n - metros) * 100)
    var texto = convertir(metros) + ' METROS CUADRADOS'
    if (cm > 0) texto += ' CON ' + convertir(cm) + (cm === 1 ? ' CENTÍMETRO' : ' CENTÍMETROS')
    return texto
  }

  function superficieHaALetras(ha, a, ca) {
    var partes = []
    if (ha > 0) partes.push(convertir(ha) + (ha === 1 ? ' HECTÁREA' : ' HECTÁREAS'))
    if (a > 0)  partes.push(convertir(a)  + (a  === 1 ? ' ÁREA' : ' ÁREAS'))
    if (ca > 0) partes.push(convertir(Math.floor(ca)) + (Math.floor(ca) === 1 ? ' CENTIÁREA' : ' CENTIÁREAS'))
    return partes.join(', ')
  }

  poligonosVars.forEach(function(_datos, idx) {
    var inputSupM2 = document.getElementById('superficie_m2_' + idx)
    var supLetras  = document.getElementById('superficie_letras_' + idx)
    var inputHa    = document.getElementById('sup_ha_' + idx)
    var inputA     = document.getElementById('sup_a_' + idx)
    var inputCa    = document.getElementById('sup_ca_' + idx)

    if (inputSupM2 && supLetras) {
      inputSupM2.addEventListener('input', function() {
        supLetras.value = superficieALetrasM2(inputSupM2.value)
      })
    }

    function actualizarLetrasRural() {
      if (!supLetras) return
      var ha = parseFloat(inputHa?.value) || 0
      var a  = parseFloat(inputA?.value)  || 0
      var ca = parseFloat(inputCa?.value) || 0
      supLetras.value = superficieHaALetras(ha, a, ca)
    }

    if (inputHa) inputHa.addEventListener('input', actualizarLetrasRural)
    if (inputA)  inputA.addEventListener('input',  actualizarLetrasRural)
    if (inputCa) inputCa.addEventListener('input', actualizarLetrasRural)
  })
</script>

<script>
  // Nombre de archivo visible + subida/eliminación de DNI sin recargar la página
  const DNI_BOX = 'width:140px;height:92px;border-radius:8px;overflow:hidden;background:var(--color-surface)'
  function renderPreviewVacio(comitenteId, lado) {
    return '<div class="dni-preview-inner" style="' + DNI_BOX + ';border:1px dashed var(--color-border);background:var(--color-bg)">' +
      '<div class="dni-placeholder" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:0.72rem;color:var(--color-text-secondary)">Sin cargar</div>' +
      '</div>'
  }
  function renderPreviewArchivo(url, lado, esImagen, comitenteId) {
    const contenido = esImagen
      ? '<a href="' + url + '" target="_blank" style="display:block;width:100%;height:100%"><img src="' + url + '" alt="DNI ' + lado + '" class="dni-img" style="width:100%;height:100%;object-fit:cover;display:block" /></a>'
      : '<a href="' + url + '" class="badge badge-finalizado" style="text-decoration:none">Ver PDF</a>'
    const btn = '<button type="button" class="dni-remove-btn" data-comitente-id="' + comitenteId + '" data-lado="' + lado + '" title="Quitar imagen">✕</button>'
    return '<div class="dni-preview-inner" style="position:relative;' + DNI_BOX + ';border:1px solid var(--color-border)">' + contenido + btn + '</div>'
  }

  // Modal de confirmación para quitar imagen de DNI
  const overlayDni    = document.getElementById('modal-overlay-dni')
  const dniLadoLabel  = document.getElementById('modal-dni-lado')
  const btnDniCancel  = document.getElementById('modal-dni-cancel')
  const btnDniConfirm = document.getElementById('modal-dni-confirm')
  let dniPendiente = null

  function cerrarModalDni() { overlayDni.hidden = true; dniPendiente = null }

  document.addEventListener('click', function(e) {
    const btn = e.target.closest('.dni-remove-btn')
    if (!btn) return
    dniPendiente = { comitenteId: btn.dataset.comitenteId, lado: btn.dataset.lado, btn: btn }
    dniLadoLabel.textContent = btn.dataset.lado === 'dorso' ? 'Dorso' : 'Frente'
    overlayDni.hidden = false
  })

  btnDniCancel.addEventListener('click', cerrarModalDni)
  overlayDni.addEventListener('click', function(e) { if (e.target === overlayDni) cerrarModalDni() })
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && !overlayDni.hidden) cerrarModalDni() })

  btnDniConfirm.addEventListener('click', function() {
    if (!dniPendiente) return
    const { comitenteId, lado, btn } = dniPendiente
    const previewWrap = document.querySelector(
      '.dni-preview-wrap[data-comitente-id="' + comitenteId + '"][data-lado="' + lado + '"]'
    )
    btn.disabled = true
    cerrarModalDni()

    const fd = new FormData()
    fd.append('comitente_id', comitenteId)
    fd.append('lado', lado)

    fetch('/api/comitentes/eliminar-dni', { method: 'POST', body: fd })
      .then(function(res) { return res.json() })
      .then(function(data) {
        if (data.ok && previewWrap) {
          previewWrap.innerHTML = renderPreviewVacio(comitenteId, lado)
        } else if (!data.ok) {
          alert('No se pudo quitar la imagen.')
        }
      })
      .catch(function() { alert('No se pudo quitar la imagen.') })
  })

  // Modal de confirmación para eliminar documento generado
  const overlayDoc    = document.getElementById('modal-overlay-doc')
  const docTipoLabel  = document.getElementById('modal-doc-tipo')
  const docFechaLabel = document.getElementById('modal-doc-fecha')
  const btnDocCancel  = document.getElementById('modal-doc-cancel')
  const btnDocConfirm = document.getElementById('modal-doc-confirm')
  let formDocPendiente = null

  function cerrarModalDoc() { overlayDoc.hidden = true; formDocPendiente = null }

  function actualizarContadorDocumentos(delta) {
    const titulo = document.getElementById('documentos_titulo')
    if (!titulo) return
    const actual = parseInt((titulo.textContent.match(/\((\d+)\)/) || [])[1] || '0')
    const nuevo = Math.max(0, actual + delta)
    titulo.textContent = 'Documentos generados (' + nuevo + ')'
  }

  function formatearFechaHora(iso) {
    const d = new Date(iso)
    const pad = function(n) { return String(n).padStart(2, '0') }
    return pad(d.getDate()) + '/' + pad(d.getMonth() + 1) + '/' + d.getFullYear() + ', ' + pad(d.getHours()) + ':' + pad(d.getMinutes())
  }

  // Destaca una fila en verde y la desvanece sola, vía estilos inline (no depende de animationend)
  function destacarFilaNueva(tr) {
    tr.style.backgroundColor = 'rgba(16,185,129,0.30)'
    setTimeout(function() { tr.style.backgroundColor = '' }, 900)
  }

  // Desvanece y quita una fila de forma determinística (setTimeout, no animationend)
  function quitarFilaConTransicion(tr, callback) {
    tr.style.backgroundColor = 'rgba(239,68,68,0.16)'
    tr.style.opacity = '0'
    setTimeout(function() {
      tr.remove()
      if (callback) callback()
    }, 320)
  }

  function crearFilaDocumento(doc) {
    const tr = document.createElement('tr')
    tr.setAttribute('data-doc-row', '')
    const tipoLabel = doc.tipo_documento.replace(/_/g, ' ')
    const estadoHtml = doc.estado === 'error_storage'
      ? '<span class="badge badge-borrador">sin archivo</span>'
      : '<span class="badge badge-finalizado">generado</span>'
    const descargaHtml = doc.storage_path
      ? '<a href="/api/documentos/descargar?path=' + doc.storage_path + '" class="btn btn-secondary btn-sm btn-descargar-pdf" data-tipo="' + tipoLabel + '">Descargar</a>'
      : '<span style="color:var(--color-muted);font-size:0.8125rem">No disponible</span>'
    const fechaTexto = formatearFechaHora(doc.generado_at)
    tr.innerHTML =
      '<td style="text-transform:capitalize">' + tipoLabel + '</td>' +
      '<td>' + fechaTexto + '</td>' +
      '<td>' + estadoHtml + '</td>' +
      '<td>' + descargaHtml + '</td>' +
      '<td><form class="form-eliminar-documento" style="display:inline" data-tipo="' + tipoLabel + '" data-fecha="' + fechaTexto + '" data-documento-id="' + doc.id + '">' +
        '<button type="button" class="btn btn-danger btn-sm btn-eliminar-doc-trigger">Eliminar</button></form></td>'
    return tr
  }

  // Delegación: funciona también para filas insertadas dinámicamente al generar
  document.addEventListener('click', function(e) {
    const btn = e.target.closest('.btn-eliminar-doc-trigger')
    if (!btn) return
    const form = btn.closest('.form-eliminar-documento')
    formDocPendiente = form
    docTipoLabel.textContent = form.dataset.tipo || '—'
    docFechaLabel.textContent = form.dataset.fecha || '—'
    overlayDoc.hidden = false
  })

  btnDocCancel.addEventListener('click', cerrarModalDoc)
  overlayDoc.addEventListener('click', function(e) { if (e.target === overlayDoc) cerrarModalDoc() })
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && !overlayDoc.hidden) cerrarModalDoc() })

  // Vista previa de PDF en un modal (sin navegar a otra página) — la página de atrás sigue
  // abierta, atenuada por el overlay. Funciona tanto para las filas ya renderizadas como para
  // las que se insertan dinámicamente al generar (delegación de eventos, mismo criterio que
  // el resto de los modales de esta página).
  const overlayPdf   = document.getElementById('modal-overlay-pdf')
  const pdfTitulo    = document.getElementById('modal-pdf-title')
  const pdfEstado    = document.getElementById('modal-pdf-estado')
  const pdfFrame     = document.getElementById('modal-pdf-frame')
  const pdfDescargar = document.getElementById('modal-pdf-descargar')
  const btnPdfClose  = document.getElementById('modal-pdf-close')
  const btnPdfCerrar = document.getElementById('modal-pdf-cerrar')

  function cerrarModalPdf() {
    overlayPdf.hidden = true
    pdfFrame.hidden = true
    pdfFrame.src = 'about:blank'
  }

  document.addEventListener('click', function(e) {
    const link = e.target.closest('.btn-descargar-pdf')
    if (!link) return
    e.preventDefault()

    const href = link.getAttribute('href')
    pdfTitulo.textContent = link.dataset.tipo ? ('Vista previa — ' + link.dataset.tipo) : 'Vista previa del documento'
    pdfDescargar.href = href
    pdfEstado.hidden = false
    pdfEstado.textContent = 'Cargando…'
    pdfFrame.hidden = true
    overlayPdf.hidden = false

    fetch(href, { headers: { 'X-Requested-With': 'fetch' } })
      .then(function(res) { return res.json() })
      .then(function(data) {
        if (!data.ok) {
          pdfEstado.textContent = 'El PDF todavía no fue generado o no se pudo cargar.'
          return
        }
        pdfDescargar.href = data.url
        pdfFrame.src = data.url
        pdfFrame.hidden = false
        pdfEstado.hidden = true
      })
      .catch(function() { pdfEstado.textContent = 'No se pudo cargar la vista previa.' })
  })

  btnPdfClose.addEventListener('click', cerrarModalPdf)
  btnPdfCerrar.addEventListener('click', cerrarModalPdf)
  overlayPdf.addEventListener('click', function(e) { if (e.target === overlayPdf) cerrarModalPdf() })
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && !overlayPdf.hidden) cerrarModalPdf() })

  btnDocConfirm.addEventListener('click', function() {
    if (!formDocPendiente) return
    const form = formDocPendiente
    const docId = form.dataset.documentoId
    const fila = form.closest('tr')
    cerrarModalDoc()

    const fd = new FormData()
    fd.append('documento_id', docId)

    fetch('/api/documentos/eliminar', { method: 'POST', body: fd })
      .then(function(res) { return res.json() })
      .then(function(data) {
        if (!data.ok) { alert('No se pudo eliminar el documento.'); return }
        if (fila) {
          quitarFilaConTransicion(fila, function() {
            actualizarContadorDocumentos(-1)
            const tbody = document.getElementById('documentos_tbody')
            if (tbody && !tbody.querySelector('[data-doc-row]')) {
              tbody.innerHTML = '<tr id="documentos_vacio"><td colspan="5" style="text-align:center;color:var(--color-text-secondary);padding:1.5rem">Todavía no se generó ningún documento.</td></tr>'
            }
          })
        }
      })
      .catch(function() { alert('No se pudo eliminar el documento.') })
  })

  // ── Validación de datos requeridos antes de generar documentos ──────────
  const DOC_LABELS_VALIDACION = {
    caratula: 'Carátula',
    nota_elevacion: 'Nota de Elevación a la Directora',
    documento_identidad: 'Fotocopia del DNI del/los Comitente/s',
    capitulo_ubicacion: 'Capítulo de Extensión, Límites e Inscripciones',
    citacion_linderos: 'Notificación a Linderos y Autoridades',
    acta_mensura: 'Acta de Mensura y Amojonamiento',
    acta_ausencia_linderos: 'Acta de Ausencia de Linderos y Autoridades',
    memoria_mensura: 'Memoria de Mensura',
    planilla_calculos: 'Planilla de Cálculos',
    formulario_u: 'Formulario "U" — Declaración Jurada',
    formulario_sor: 'Formulario "SOR" — Declaración Jurada',
    formulario_e1: 'Formulario "E1" — Características constructivas',
  }

  const datosValidacion = window.datosValidacion || {}
  const linderosLabel = 'Los 4 linderos de mensura (Tab 3 Mensura)'
  const REQUISITOS_DOC = {
    caratula: [
      { ok: datosValidacion.tieneComitente, label: 'Comitente cargado (Tab 1 Comitente)' },
      { ok: datosValidacion.inmuebleDepartamento, label: 'Departamento del inmueble (Tab 2 Inmueble)' },
      { ok: datosValidacion.inmueblePartida, label: 'Partida Inmobiliaria (Tab 2 Inmueble)' },
    ],
    nota_elevacion: [
      { ok: datosValidacion.tieneComitente, label: 'Comitente cargado (Tab 1 Comitente)' },
      { ok: datosValidacion.comitenteDni, label: 'DNI del comitente (Tab 1 Comitente)' },
      { ok: datosValidacion.inmuebleLocalidad, label: 'Localidad del inmueble (Tab 2 Inmueble)' },
      { ok: datosValidacion.inmueblePartida, label: 'Partida Inmobiliaria (Tab 2 Inmueble)' },
      { ok: datosValidacion.profileNombre, label: 'Nombre y apellido del profesional (Mi Perfil)' },
      { ok: datosValidacion.profileDni, label: 'DNI del profesional (Mi Perfil)' },
      { ok: datosValidacion.profileMatricula, label: 'Matrícula Consejo (Mi Perfil)' },
      { ok: datosValidacion.profileMatriculaCatastro, label: 'Matrícula Catastro (Mi Perfil)' },
    ],
    documento_identidad: [
      { ok: datosValidacion.tieneComitente, label: 'Al menos un comitente cargado (Tab 1 Comitente)' },
    ],
    capitulo_ubicacion: [
      { ok: datosValidacion.inmuebleDepartamento, label: 'Departamento del inmueble (Tab 2 Inmueble)' },
      { ok: datosValidacion.superficie, label: 'Superficie del polígono (Tab 3 Mensura)' },
      { ok: datosValidacion.linderosCompletos, label: linderosLabel },
    ],
    citacion_linderos: [
      { ok: datosValidacion.tieneComitente, label: 'Comitente cargado (Tab 1 Comitente)' },
      { ok: datosValidacion.comitenteDni, label: 'DNI del comitente (Tab 1 Comitente)' },
      { ok: datosValidacion.inmuebleLocalidad, label: 'Localidad del inmueble (Tab 2 Inmueble)' },
      { ok: datosValidacion.fechaMensura, label: 'Fecha de mensura (Tab 3 Mensura)' },
      { ok: datosValidacion.horaMensura, label: 'Hora de mensura (Tab 3 Mensura)' },
      { ok: datosValidacion.linderosCompletos, label: linderosLabel },
    ],
    acta_mensura: [
      { ok: datosValidacion.profileNombre, label: 'Nombre y apellido del profesional (Mi Perfil)' },
      { ok: datosValidacion.profileDni, label: 'DNI del profesional (Mi Perfil)' },
      { ok: datosValidacion.profileMatricula, label: 'Matrícula Consejo (Mi Perfil)' },
      { ok: datosValidacion.fechaMensura, label: 'Fecha de mensura (Tab 3 Mensura)' },
      { ok: datosValidacion.horaMensura, label: 'Hora de mensura (Tab 3 Mensura)' },
      { ok: datosValidacion.tieneComitente, label: 'Comitente cargado (Tab 1 Comitente)' },
      { ok: datosValidacion.comitenteDni, label: 'DNI del comitente (Tab 1 Comitente)' },
      { ok: datosValidacion.superficie, label: 'Superficie del polígono (Tab 3 Mensura)' },
      { ok: datosValidacion.superficieLetras, label: 'Superficie en letras (Tab 3 Mensura)' },
      { ok: datosValidacion.linderosCompletos, label: linderosLabel },
    ],
    acta_ausencia_linderos: [
      { ok: datosValidacion.profileNombre, label: 'Nombre y apellido del profesional (Mi Perfil)' },
      { ok: datosValidacion.profileDni, label: 'DNI del profesional (Mi Perfil)' },
      { ok: datosValidacion.fechaMensura, label: 'Fecha de mensura (Tab 3 Mensura)' },
      { ok: datosValidacion.horaMensura, label: 'Hora de mensura (Tab 3 Mensura)' },
      { ok: datosValidacion.linderosCompletos, label: linderosLabel },
    ],
    memoria_mensura: [
      { ok: datosValidacion.cantLados > 0, label: 'Lados del polígono cargados (Tab 3 Mensura)' },
      { ok: datosValidacion.cantAngulos > 0, label: 'Ángulos del polígono cargados (Tab 3 Mensura)' },
      { ok: datosValidacion.superficie, label: 'Superficie del polígono (Tab 3 Mensura)' },
      { ok: datosValidacion.superficieLetras, label: 'Superficie en letras (Tab 3 Mensura)' },
    ],
    planilla_calculos: [
      { ok: datosValidacion.cantLados > 0, label: 'Lados del polígono cargados (Tab 3 Mensura)' },
      { ok: datosValidacion.cantAngulos > 0, label: 'Ángulos del polígono cargados (Tab 3 Mensura)' },
      { ok: datosValidacion.superficie, label: 'Superficie del polígono (Tab 3 Mensura)' },
    ],
    formulario_u: [
      { ok: datosValidacion.inmuebleEsUrbano, label: 'Inmueble cargado como "Urbano" (Tab 2 Inmueble)' },
      { ok: datosValidacion.tieneComitente, label: 'Comitente cargado (Tab 1 Comitente)' },
      { ok: datosValidacion.comitenteDni, label: 'DNI del comitente (Tab 1 Comitente)' },
      { ok: datosValidacion.inmuebleLocalidad, label: 'Localidad del inmueble (Tab 2 Inmueble)' },
      { ok: datosValidacion.superficie, label: 'Superficie del polígono (Tab 3 Mensura)' },
      { ok: datosValidacion.comitenteNacionalidad, label: 'Nacionalidad del comitente (Tab 5 DDJJ)' },
      { ok: datosValidacion.comitenteDomicilio, label: 'Domicilio del comitente (Tab 5 DDJJ)' },
    ],
    formulario_sor: [
      { ok: datosValidacion.inmuebleEsRural, label: 'Inmueble cargado como "Rural" (Tab 2 Inmueble)' },
      { ok: datosValidacion.tieneComitente, label: 'Comitente cargado (Tab 1 Comitente)' },
      { ok: datosValidacion.comitenteDni, label: 'DNI del comitente (Tab 1 Comitente)' },
      { ok: datosValidacion.inmuebleLocalidad, label: 'Localidad del inmueble (Tab 2 Inmueble)' },
      { ok: datosValidacion.comitenteDomicilio, label: 'Domicilio del comitente (Tab 5 DDJJ)' },
    ],
    formulario_e1: [
      { ok: datosValidacion.tieneComitente, label: 'Comitente cargado (Tab 1 Comitente)' },
      { ok: datosValidacion.inmuebleLocalidad, label: 'Localidad del inmueble (Tab 2 Inmueble)' },
      { ok: datosValidacion.edificacionCargada, label: '¿El inmueble tiene construcciones? tildado (Tab 5 DDJJ)' },
      { ok: datosValidacion.edificacionCaracteristicas, label: 'Al menos una característica de Rubro 1 cargada (Tab 5 DDJJ)' },
    ],
  }

  const overlayValidacion = document.getElementById('modal-overlay-validacion')
  const listaValidacion = document.getElementById('modal-validacion-lista')
  const btnValidacionCerrar = document.getElementById('modal-validacion-cerrar')
  if (btnValidacionCerrar) {
    btnValidacionCerrar.addEventListener('click', function() { overlayValidacion.hidden = true })
    overlayValidacion.addEventListener('click', function(e) { if (e.target === overlayValidacion) overlayValidacion.hidden = true })
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && !overlayValidacion.hidden) overlayValidacion.hidden = true })
  }

  // Devuelve { tipo: [labels faltantes] } solo para los tipos marcados que tengan algo pendiente
  function validarDocumentosSeleccionados(tipos) {
    const faltantes = {}
    tipos.forEach(function(tipo) {
      const reqs = REQUISITOS_DOC[tipo]
      if (!reqs) return
      const pendientes = reqs.filter(function(r) { return !r.ok }).map(function(r) { return r.label })
      if (pendientes.length) faltantes[tipo] = pendientes
    })
    return faltantes
  }

  function mostrarModalValidacion(faltantes) {
    listaValidacion.innerHTML = ''
    Object.keys(faltantes).forEach(function(tipo) {
      const grupo = document.createElement('div')
      grupo.className = 'validacion-doc'
      const titulo = document.createElement('div')
      titulo.className = 'validacion-doc-titulo'
      titulo.textContent = DOC_LABELS_VALIDACION[tipo] || tipo
      grupo.appendChild(titulo)
      faltantes[tipo].forEach(function(label) {
        const item = document.createElement('div')
        item.className = 'validacion-item'
        item.innerHTML = '<span>•</span><span>' + label + '</span>'
        grupo.appendChild(item)
      })
      listaValidacion.appendChild(grupo)
    })
    overlayValidacion.hidden = false
  }

  // Generar documentos sin recargar la página
  const formGenerarDocs = document.getElementById('form_generar_seleccionados')
  if (formGenerarDocs) {
    formGenerarDocs.addEventListener('submit', function(e) {
      e.preventDefault()
      const btnSubmit = formGenerarDocs.querySelector('button[type="submit"]')
      const tiposMarcados = formGenerarDocs.querySelectorAll('input[name="tipos[]"]:checked')
      if (!tiposMarcados.length) { alert('Seleccioná al menos un documento para generar.'); return }

      const faltantes = validarDocumentosSeleccionados(Array.prototype.map.call(tiposMarcados, function(chk) { return chk.value }))
      if (Object.keys(faltantes).length) {
        mostrarModalValidacion(faltantes)
        return
      }

      btnSubmit.disabled = true
      const textoOriginal = btnSubmit.textContent
      btnSubmit.textContent = 'Generando...'

      fetch(formGenerarDocs.action, {
        method: 'POST',
        body: new FormData(formGenerarDocs),
        headers: { 'X-Requested-With': 'fetch' },
      })
        .then(function(res) { return res.json() })
        .then(function(data) {
          if (!data.ok) {
            const mensajesGenerar = {
              ddjj_no_implementada: 'Ese formulario de Declaración Jurada todavía no está implementado.',
              ddjj_falta_inmueble: 'Completá primero la Tab 2 Inmueble antes de generar la Declaración Jurada.',
              ddjj_tipo_incorrecto: 'El Formulario U es solo para inmuebles urbanos y el SOR solo para rurales — revisá el tipo de inmueble cargado en la Tab 2.',
            }
            alert(mensajesGenerar[data.warn] || 'No se pudieron generar los documentos.')
            return
          }
          const tbody = document.getElementById('documentos_tbody')
          const vacio = document.getElementById('documentos_vacio')
          if (vacio) vacio.remove()
          data.documentos.slice().reverse().forEach(function(doc) {
            const fila = crearFilaDocumento(doc)
            tbody.insertBefore(fila, tbody.firstChild)
            destacarFilaNueva(fila)
          })
          actualizarContadorDocumentos(data.documentos.length)
          tiposMarcados.forEach(function(chk) { chk.checked = false })
        })
        .catch(function() { alert('No se pudieron generar los documentos.') })
        .finally(function() {
          btnSubmit.disabled = false
          btnSubmit.textContent = textoOriginal
        })
    })
  }

  // Generar expediente completo en un solo PDF — misma lógica de validación que "Generar
  // seleccionados", pero con la lista fija de tipos que arma también el servidor (los 8
  // documentos base + la DDJJ que corresponda + E1 si hay datos cargados).
  const formExpedienteCompleto = document.getElementById('form_expediente_completo')
  if (formExpedienteCompleto) {
    formExpedienteCompleto.addEventListener('submit', function(e) {
      e.preventDefault()
      // El botón vive visualmente en el otro formulario (agrupado en la misma fila con
      // "Generar seleccionados", ver .botones-generar-fila) y apunta acá con el atributo
      // form="form_expediente_completo" — por eso no es descendiente de este <form> y hay que
      // buscarlo en todo el documento, no con formExpedienteCompleto.querySelector(...).
      const btnSubmit = document.querySelector('button[form="form_expediente_completo"]')

      const tiposBundle = ['caratula', 'nota_elevacion', 'documento_identidad', 'capitulo_ubicacion', 'acta_mensura', 'acta_ausencia_linderos', 'memoria_mensura', 'planilla_calculos']
      tiposBundle.push(datosValidacion.inmuebleEsRural ? 'formulario_sor' : 'formulario_u')
      if (datosValidacion.edificacionCargada) tiposBundle.push('formulario_e1')

      const faltantes = validarDocumentosSeleccionados(tiposBundle)
      if (Object.keys(faltantes).length) {
        mostrarModalValidacion(faltantes)
        return
      }

      btnSubmit.disabled = true
      const textoOriginal = btnSubmit.textContent
      btnSubmit.textContent = 'Generando...'

      fetch(formExpedienteCompleto.action, {
        method: 'POST',
        body: new FormData(formExpedienteCompleto),
        headers: { 'X-Requested-With': 'fetch' },
      })
        .then(function(res) { return res.json() })
        .then(function(data) {
          if (!data.ok) {
            alert('No se pudo generar el expediente completo.')
            return
          }
          const tbody = document.getElementById('documentos_tbody')
          const vacio = document.getElementById('documentos_vacio')
          if (vacio) vacio.remove()
          data.documentos.slice().reverse().forEach(function(doc) {
            const fila = crearFilaDocumento(doc)
            tbody.insertBefore(fila, tbody.firstChild)
            destacarFilaNueva(fila)
          })
          actualizarContadorDocumentos(data.documentos.length)
        })
        .catch(function() { alert('No se pudo generar el expediente completo.') })
        .finally(function() {
          btnSubmit.disabled = false
          btnSubmit.textContent = textoOriginal
        })
    })
  }

  document.querySelectorAll('.dni-upload-form').forEach(function(form) {
    const fileInput  = form.querySelector('.dni-file-input')
    const fileName    = form.querySelector('.file-name')
    const submitBtn  = form.querySelector('.dni-submit-btn')
    const lado         = form.querySelector('input[name="lado"]').value
    const comitenteId = form.querySelector('input[name="comitente_id"]').value
    const previewWrap = document.querySelector(
      '.dni-preview-wrap[data-comitente-id="' + comitenteId + '"][data-lado="' + lado + '"]'
    )

    fileInput.addEventListener('change', function() {
      const f = fileInput.files[0]
      fileName.textContent = f ? f.name : 'Sin archivo seleccionado'
      fileName.classList.toggle('has-file', !!f)
    })

    form.addEventListener('submit', function(e) {
      e.preventDefault()
      const file = fileInput.files[0]
      if (!file) return

      submitBtn.disabled = true
      submitBtn.textContent = 'Subiendo...'

      fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'X-Requested-With': 'fetch' },
      })
        .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data } }) })
        .then(function(result) {
          if (!result.ok || !result.data.ok) {
            const mensajes = {
              archivo_requerido: 'Seleccioná un archivo para subir.',
              formato_invalido: 'Formato no válido. Usá JPG, PNG o PDF.',
              error_storage: 'Error al subir el archivo. Probá de nuevo.',
            }
            alert(mensajes[result.data.warn] || 'No se pudo subir el archivo.')
            return
          }
          const ext = file.name.split('.').pop().toLowerCase()
          const url = '/api/documentos/descargar?path=' + result.data.path + '&t=' + Date.now()
          const esImagen = ['jpg','jpeg','png'].indexOf(ext) !== -1
          if (previewWrap) {
            previewWrap.innerHTML = renderPreviewArchivo(url, lado, esImagen, comitenteId)
          }
          fileInput.value = ''
          fileName.textContent = 'Sin archivo seleccionado'
          fileName.classList.remove('has-file')
        })
        .catch(function() {
          alert('No se pudo subir el archivo. Probá de nuevo.')
        })
        .finally(function() {
          submitBtn.disabled = false
          submitBtn.textContent = 'Subir'
        })
    })
  })
</script>

<style>
.page-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:1.5rem; gap:1rem; flex-wrap:wrap; }
.back-link { font-size:0.875rem; color:var(--color-text-secondary); display:block; margin-bottom:0.25rem; text-decoration:none; }
