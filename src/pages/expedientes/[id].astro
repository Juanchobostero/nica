.dni-submit-btn[disabled] { opacity:0.6; cursor:not-allowed; }
.btn-disabled { opacity:0.4; pointer-events:none; }

/* Transiciones de filas de documentos generados (controladas desde JS, no por keyframes,
   ya que animar transform/opacity con animationend en <tr> no es confiable entre navegadores) */
tr[data-doc-row] { transition: background-color 1.6s ease, opacity 0.3s ease; }

/* Modal confirmación (estilo shadcn) */
.modal-overlay {
  position:fixed; inset:0; background:rgba(15,23,42,0.5);
  display:flex; align-items:center; justify-content:center; z-index:1000;
  animation:modal-fade-in 0.15s ease-out;
}
.modal-overlay[hidden] { display:none; }
.modal-card {
  background:var(--color-surface); border-radius:var(--radius-lg);
  box-shadow:var(--shadow-md); padding:1.5rem; width:100%; max-width:400px;
  margin:1rem; animation:modal-pop-in 0.15s ease-out;
}
.modal-icon {
  width:40px; height:40px; border-radius:50%;
  background:#FEF2F2; color:var(--color-danger);
  display:flex; align-items:center; justify-content:center; margin-bottom:0.875rem;
}
.modal-card h3 { font-size:1.05rem; font-weight:700; color:var(--color-text); margin-bottom:0.4rem; }
