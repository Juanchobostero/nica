.poligono-card-label { font-weight:700; font-size:0.95rem; color:var(--color-primary); }
.lados-header { display:grid; grid-template-columns:48px 1fr 1fr; gap:0.5rem; padding:0.25rem 0; font-size:0.75rem; font-weight:600; color:var(--color-text-secondary); text-transform:uppercase; letter-spacing:0.04em; }
.lado-fila { display:grid; grid-template-columns:48px 1fr 1fr; gap:0.5rem; margin-bottom:0.5rem; align-items:center; }
.lado-num { font-weight:700; color:var(--color-primary); font-size:0.875rem; }
.lados-suma { font-size:0.875rem; font-weight:600; color:var(--color-primary); margin-top:0.5rem; padding:0.5rem 0.75rem; background:var(--color-bg); border-radius:var(--radius-sm); display:inline-block; }
.visor-angulos { background:var(--color-surface); border:1px solid var(--color-border); border-radius:var(--radius-md); padding:0.875rem 1.125rem; box-shadow:0 1px 4px rgba(27,46,94,.07); }
.visor-inner { display:flex; align-items:center; gap:1.25rem; }
.visor-titulo { font-size:0.7rem; font-weight:700; color:var(--color-text-secondary); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.5rem; }
.visor-lista { display:flex; flex-direction:column; gap:0.2rem; margin-bottom:0.5rem; }
.visor-fila { display:flex; align-items:center; gap:0.5rem; }
.visor-num { font-weight:700; color:var(--color-primary); font-size:0.78rem; min-width:22px; }
.visor-dms { font-family:monospace; font-size:0.85rem; color:var(--color-text); }
.visor-suma { font-size:0.82rem; font-weight:600; color:var(--color-primary); border-top:1px solid var(--color-border); padding-top:0.375rem; margin-top:0.25rem; }

/* DNI preview + upload (tamaño fijo via inline style, acá solo comportamiento) */
.dni-preview-wrap { display:flex; flex-direction:column; gap:0.35rem; }
.dni-img { cursor:zoom-in; transition:transform 0.25s ease; }
.dni-preview-inner:hover .dni-img { transform:scale(1.18); }
.dni-placeholder {
  width:100%; height:100%; display:flex; align-items:center; justify-content:center;
  font-size:0.72rem; color:var(--color-text-secondary);
}
.dni-remove-btn {
  position:absolute; top:5px; right:5px; z-index:2;
  width:22px; height:22px; border-radius:50%; border:none;
  background:rgba(15,23,42,0.55); color:#fff; font-size:0.7rem; line-height:1;
  display:flex; align-items:center; justify-content:center; cursor:pointer;
  opacity:0; transition:opacity 0.15s ease, background 0.15s ease;
}
.dni-preview-inner:hover .dni-remove-btn { opacity:1; }
.dni-remove-btn:hover { background:rgba(220,38,38,0.85); }
.file-btn {
  display:inline-flex; align-items:center; gap:0.4rem; width:fit-content;
  padding:0.4rem 0.7rem; background:var(--color-surface); border:1px solid var(--color-border);
  border-radius:var(--radius-sm); font-size:0.78rem; font-weight:500; color:var(--color-text);
